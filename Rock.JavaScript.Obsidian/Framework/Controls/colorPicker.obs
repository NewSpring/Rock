            "700": "#a800b7",
            "800": "#8a0194",
            "900": "#721378",
            "950": "#4b004f"
        }),
        createSwatchItem("Pink", "#f6339a", {
            "50": "#fdf2f8",
            "100": "#fce7f3",
            "200": "#fccee8",
            "300": "#fda5d5",
            "400": "#fb64b6",
            "500": "#f6339a",
            "600": "#e60076",
            "700": "#c6005c",
            "800": "#a3004c",
            "900": "#861043",
            "950": "#510424"
        }),
        createSwatchItem("Rose", "#ff2056", {
            "50": "#fff1f2",
            "100": "#ffe4e6",
            "200": "#ffccd3",
            "300": "#ffa1ad",
            "400": "#ff637e",
            "500": "#ff2056",
            "600": "#ec003f",
            "700": "#c70036",
            "800": "#a50036",
            "900": "#8b0836",
            "950": "#4d0218"
        }),
    ];

    const chunkedDefaultSwatches = Enumerable
        .from(defaultSimpleViewSwatchItems)
        .chunk(SIMPLE_VIEW_SWATCHES_PER_ROW)
        .toArray();

    // #region Values

    // UI state
    const colorPicker = ref<HTMLElement>();
    const popoverButton = ref<HTMLElement>();
    const popover = ref<HTMLElement>();
    const popoverStyle = ref<Record<string, string>>({});
    const isOpen = ref(false);
    const svArea = ref<HTMLElement>();
    const hueArea = ref<HTMLElement>();
    const alphaArea = ref<HTMLElement>();
    const isTyping = ref(false);
    const currentFormat = ref<ColorFormat | null>(null);
    const displayValue = ref(props.modelValue ?? "");
    const openBaselineValue = ref<string>("");
    const isAdvancedViewVisible = ref(false);
    const activeDrag = ref<DragTarget | null>(null);
    const hue = ref<number>(0);          // 0–360
    const saturation = ref<number>(100); // 0–100
    const value = ref<number>(100);      // 0–100
    const alpha = ref<number>(1); // 0–1
    const definedValueSwatchItems = ref<SwatchItemWithLocation[]>([]);

    // #endregion Values

    // #region Computed Values

    const selectedSimpleViewSwatchItem = computed<SwatchItem | null>(() => {
        const selectedHexValue = selectedHex.value;
        if (!selectedHexValue) {
            return null;
        }

        // Select the first matching palette color, checking both base and shades for a match.
        // This allows the selected color to be highlighted in the palette even if it's not an exact match for the base color (e.g., a shade of the palette color).
        // It also prevents highlighting multiple matches when the palette contains both a base color and one of its shades that are the same as the selected color.
        let foundSwatchItem = Enumerable
            .from(definedValuePaletteColorSwatchItems.value)
            .firstOrDefault(c =>
                c.normalizedHex === selectedHexValue
                || !!c.shades?.some(s => s.normalizedHex === selectedHexValue)
            );

        if (foundSwatchItem) {
            return foundSwatchItem;
        }

        foundSwatchItem = Enumerable
            .from(defaultSimpleViewSwatchItems)
            .firstOrDefault(c =>
                c.normalizedHex === selectedHexValue
                || !!c.shades?.some(s => s.normalizedHex === selectedHexValue)
            );

        return foundSwatchItem ?? null;
    });

    const definedValuePaletteColorSwatchItems = computed<SwatchItem[]>(() => {
        return definedValueSwatchItems.value.filter(
            s => s.displayLocation === "Palette Color" && !!s.color
        );
    });

    const definedValueCustomSwatchItems = computed<SwatchItem[]>(() => {
        return definedValueSwatchItems.value.filter(
            s => s.displayLocation === "Custom"
        );
    });

    const svStyle = computed(() => ({
        background: `
            linear-gradient(to top, black, transparent),
            linear-gradient(to right, white, transparent),
            hsl(${hue.value}, 100%, 50%)
        `
    }));

    const svIndicatorStyle = computed(() => ({
        left: `${saturation.value}%`,
        top: `${100 - value.value}%`
    }));


    const hueIndicatorStyle = computed(() => ({
        top: `${(1 - hue.value / 360) * 100}%`
    }));

    const alphaStyle = computed(() => {
        const transparent = hsvToHex(
            hue.value,
            saturation.value,
            value.value,
            0
        );

        const opaque = hsvToHex(
            hue.value,
            saturation.value,
            value.value,
            1
        );

        return {
            background: `
            linear-gradient(to top,
                ${transparent},
                ${opaque}
            ),
            repeating-conic-gradient(var(--color-interface-soft) 0% 25%, var(--color-interface-softest) 0% 50%) 0 0 / calc(var(--alpha-square-size) * 2) calc(var(--alpha-square-size) * 2)
        `
        };
    });

    const alphaIndicatorStyle = computed(() => ({
        top: `${(1 - alpha.value) * 100}%`
    }));

    const previewHex = computed(() =>
        hsvToHex(hue.value, saturation.value, value.value, alpha.value)
    );

    const previewStyle = computed(() => ({
        background: `
        linear-gradient(${previewHex.value}, ${previewHex.value}),
        repeating-conic-gradient(var(--color-interface-soft) 0% 25%, var(--color-interface-softest) 0% 50%) 0 0 / calc(var(--alpha-square-size) * 2) calc(var(--alpha-square-size) * 2)
    `
    }));

    const selectedHex = computed(() => {
        return normalizeToHex(displayValue.value ?? "") ?? null;
    });

    // #endregion Computed Values

    // #region Functions

    function isPrimaryPointer(e: PointerEvent): boolean {
        // Ignore non primary pointers and right click
        return e.isPrimary && e.button === 0;
    }

    function formatHexForOutput(hex: string): string {
        if (props.modelModifiers?.hex) {
            return hex;
        }

        switch (currentFormat.value) {
            case "rgb":
                return new RockColor(hex).toRgba();

            case "named":
                return RockColor.getKeywordFromColor(hex) ?? hex;

            case "hex":
            default:
                return hex;
        }
    }

    function createSwatchItem(name: string, color: string, shades?: Record<ShadeStop, string>): SwatchItem {
        const rockColor = new RockColor(color);
        return {
            name,
            color,
            normalizedHex: rockColor.toHex(),
            isBorderRequired: isBorderRequired(rockColor, popupBg),
            shades: shades
                ? Enumerable
                    .from(Object.entries(shades))
                    .select<ShadeSwatchItem>(([shadeStop, shadeColor]) => {
                        const shadeRockColor = new RockColor(shadeColor);
                        return {
                            name: `${name} - ${shadeStop}`,
                            color: shadeColor,
                            normalizedHex: shadeRockColor.toHex(),
                            isBorderRequired: isBorderRequired(shadeRockColor, popupBg),
                            stop: shadeStop
                        };
                    })
                    .toArray()
                : undefined
        };
    }

    function getShadowProbe(): HTMLElement {
        if (shadowProbe) {
            return shadowProbe;
        }

        shadowHost = document.createElement("div");
        shadowHost.style.position = "absolute";
        shadowHost.style.width = "0";
        shadowHost.style.height = "0";
        shadowHost.style.overflow = "hidden";
        shadowHost.style.pointerEvents = "none";

        const shadowRoot = shadowHost.attachShadow({ mode: "closed" });

        shadowProbe = document.createElement("div");
        shadowRoot.appendChild(shadowProbe);

        document.body.appendChild(shadowHost);

        return shadowProbe;
    }

    /**
     * Normalize a CSS color string to a consistent RGB format.
     * @param value The CSS color string to normalize.
     * @returns The normalized RGB color string or null if the color is invalid.
     */
    function tryNormalizeToRgb(value: string): string | null {
        if (!("attachShadow" in Element.prototype)) {
            const el = document.createElement("div");
            el.style.setProperty("color", value, "important");
            document.body.appendChild(el);
            const computedColor = getComputedStyle(el).color;
            document.body.removeChild(el);
            const rgbColor = new RockColor(computedColor).toRgba();
            return rgbColor;
        }
        else {
            const probe = getShadowProbe();
            probe.style.color = "";
            probe.style.setProperty("color", value, "important");

            if (!probe.style.color) {
                return null;
            }

            const computedColor = getComputedStyle(probe).color;
            const rgbColor = new RockColor(computedColor).toRgba();
            return rgbColor;
        }
    }

    function normalizeToHex(value: string): string | undefined {
        if (!value) {
            return;
        }

        const trimmed = value.trim();

        let hex = tryNormalizeToHex(trimmed);
        if (hex) {
            return hex;
        }

        const rgb = tryNormalizeToRgb(trimmed);
        if (rgb) {
            return new RockColor(rgb).toHex();
        }

        return;
    }

    function detectFormat(value: string): ColorFormat | null {
        if (!value) {
            return null;
        }

        const trimmed = value.trim();

        if (/^#([0-9a-f]{3,8})$/i.test(trimmed)) {
            return "hex";
        }

        if (/^rgba?\(/i.test(trimmed)) {
            return "rgb";
        }

        if (RockColor.getColorFromKeyword(trimmed.toLowerCase()) !== null) {
            return "named";
        }

        return null;
    }

    function updateFromHsv(): void {
        const hex = hsvToHex(
            hue.value,
            saturation.value,
            value.value,
            alpha.value
        );

        displayValue.value = formatHexForOutput(hex);
    }

    function updatePopoverPosition(): void {
        if (!colorPicker.value || !popover.value) {
            return;
        }

        const triggerRect = colorPicker.value.getBoundingClientRect();
        const popRect = popover.value.getBoundingClientRect();

        const placement = calculatePlacement(
            triggerRect,
            popRect.width,
            popRect.height
        );

        let position = calculatePosition(
            triggerRect,
            placement,
            popRect.width,
            popRect.height
        );

        if (!position) {
            return;
        }

        const margin = 8;

        // Clamp horizontally
        position.left = clamp(
            position.left,
            margin,
            window.innerWidth - popRect.width - margin
        );

        // Clamp vertically
        position.top = clamp(
            position.top,
            margin,
            window.innerHeight - popRect.height - margin
        );

        popoverStyle.value = {
            position: "fixed",
            top: `${position.top}px`,
            left: `${position.left}px`
        };
    }

    /**
     * Load color swatch defined type from server to display at the bottom of the picker.
     */
    async function loadColorSwatches(): Promise<ColorPickerSwatchBag[]> {
        const options: ColorPickerGetColorPickerSwatchesOptionsBag = {};

        const url = "/api/v2/Controls/ColorPickerGetColorPickerSwatches";
        const result = await http.post<ColorPickerSwatchBag[]>(url, undefined, options);

        if (result.isSuccess && result.data) {
            return result.data;
        }
        else {
            console.error(result.errorMessage ?? "Unknown error while loading data.");
            return [];
        }
    }

    function hsvToHex(h: number, s: number, v: number, a: number): string {
        s /= 100;
        v /= 100;
        h = h % 360;

        const c = v * s;
        const x = c * (1 - Math.abs((h / 60) % 2 - 1));
        const m = v - c;

        let r = 0, g = 0, b = 0;

        if (h < 60) [r, g, b] = [c, x, 0];
        else if (h < 120) [r, g, b] = [x, c, 0];
        else if (h < 180) [r, g, b] = [0, c, x];
        else if (h < 240) [r, g, b] = [0, x, c];
        else if (h < 300) [r, g, b] = [x, 0, c];
        else[r, g, b] = [c, 0, x];

        const to255 = (n: number): number =>
            Math.round((n + m) * 255);

        const r255 = to255(r);
        const g255 = to255(g);
        const b255 = to255(b);

        if (a < 1) {
            const a255 = Math.round(a * 255);
            return `#${r255.toString(16).padStart(2, "0")}${g255.toString(16).padStart(2, "0")}${b255.toString(16).padStart(2, "0")}${a255.toString(16).padStart(2, "0")}`;
        }

        return `#${r255.toString(16).padStart(2, "0")}${g255.toString(16).padStart(2, "0")}${b255.toString(16).padStart(2, "0")}`;
    }

    function hexToHsv(hex: string): { h: number, s: number, v: number, a: number } | undefined {
        if (!hex) {
            return;
        }

        const color = new RockColor(hex);

        const r = color.r / 255;
        const g = color.g / 255;
        const b = color.b / 255;

        const max = Math.max(r, g, b);
        const min = Math.min(r, g, b);
        const delta = max - min;

        let h = 0;

        if (delta !== 0) {
            if (max === r) h = 60 * (((g - b) / delta) % 6);
            else if (max === g) h = 60 * ((b - r) / delta + 2);
            else h = 60 * ((r - g) / delta + 4);
        }

        if (h < 0) h += 360;

        const s = max === 0 ? 0 : delta / max;
        const v = max;

        return {
            h: Math.round(h),
            s: Math.round(s * 100),
            v: Math.round(v * 100),
            a: color.alpha ?? 1 // NaN fallback to 1
        };
    }

    function syncFromHex(hex: string): void {
        const hsv = hexToHsv(hex);
        if (!hsv) {
            return;
        }

        if (hue.value !== hsv.h) hue.value = hsv.h;
        if (saturation.value !== hsv.s) saturation.value = hsv.s;
        if (value.value !== hsv.v) value.value = hsv.v;
        if (alpha.value !== hsv.a) alpha.value = hsv.a;
    }

    function tryNormalizeToHex(value: string): string | undefined {
        if (!value) {
            return;
        }

        const trimmed = value.trim();

        // Modern CSS also supports alpha channels (transparency).
        // This pattern accounts for 3-digit (#RGB), 4-digit (#RGBA), 6-digit (#RRGGBB), and 8-digit (#RRGGBBAA) formats.
        const isFullHex = /^#([A-Fa-f0-9]{3,4}|[A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$/.test(trimmed);

        // This pattern handles the legacy comma format and the newer space-separated format
        // with a slash for alpha, e.g., rgb(255 255 255 / 0.5) and rgba(255, 255, 255, 0.5).
        const isFullRgb = /^rgba?\(\s*(\d{1,3}(?:\s*,\s*|\s+)){2}\d{1,3}\s*(?:(?:\s*,\s*|\s*\/\s*)(?:0|1|0?\.\d+))?\s*\)$/.test(trimmed);

        const isNamed = RockColor.getColorFromKeyword(trimmed.toLowerCase()) !== null;

        if (!isFullHex && !isFullRgb && !isNamed) {
            return;
        }

        return new RockColor(trimmed).toHex();
    }

    function commitSelection(): void {
        const trimmed = displayValue.value.trim();
        emit("update:modelValue", trimmed);
        isOpen.value = false;
    }

    function cancelSelection(): void {
        const baseline = openBaselineValue.value ?? "";
        displayValue.value = baseline;

        const hex = normalizeToHex(baseline);
        if (hex) {
            syncFromHex(hex);
        }

        isOpen.value = false;
    }

    function getTooltipContent(name: string, color: string): string {
        return `${name}<br>${color.toUpperCase()}`;
    }

    function isSwatchSelected(item: SwatchItem): boolean {
        return selectedHex.value === item.normalizedHex;
    }

    function clamp(value: number, min: number, max: number): number {
        return Math.min(Math.max(value, min), max);
    }

    function isBorderRequired(
        swatch: RockColor,
        popupBg: RockColor
    ): boolean {
        const contrast = RockColor.calculateContrastRatio(swatch, popupBg);

        // If the contrast ratio is less than the minimum swatch contrast,
        // it means the swatch color is very similar to the popup background,
        // so we should add a border to ensure it's distinguishable.
        return contrast < MIN_SWATCH_CONTRAST;
    }

    function calculatePosition(
        triggerRect: DOMRect,
        placement: "bottom" | "top" | "right" | "left",
        popoverWidth: number,
        popoverHeight: number
    ): { top: number, left: number } {
        switch (placement) {
            case "bottom":
                return {
                    top: triggerRect.bottom,
                    left: triggerRect.right - popoverWidth
                };

            case "top":
                return {
                    top: triggerRect.top - popoverHeight,
                    left: triggerRect.left
                };

            case "right":
                return {
                    top: triggerRect.top,
                    left: triggerRect.right
                };

            case "left":
                return {
                    top: triggerRect.top,
                    left: triggerRect.left - popoverWidth
                };
        }
    }

    function calculatePlacement(
        triggerRect: DOMRect,
        popoverWidth: number,
        popoverHeight: number
    ): "bottom" | "top" | "right" | "left" {
        const spaceBelow = window.innerHeight - triggerRect.bottom;
        const spaceAbove = triggerRect.top;
        const spaceRight = window.innerWidth - triggerRect.right;
        const spaceLeft = triggerRect.left;

        if (spaceBelow >= popoverHeight) return "bottom";
        if (spaceAbove >= popoverHeight) return "top";
        if (spaceRight >= popoverWidth) return "right";
        if (spaceLeft >= popoverWidth) return "left";

        const verticalMax = Math.max(spaceBelow, spaceAbove);
        const horizontalMax = Math.max(spaceRight, spaceLeft);

        if (verticalMax >= horizontalMax) {
            return spaceBelow >= spaceAbove ? "bottom" : "top";
        }

        return spaceRight >= spaceLeft ? "right" : "left";
    }

    function beginDrag(
        e: PointerEvent,
        target: DragTarget,
        areaRef: HTMLElement,
        updateHandler: (e: PointerEvent) => void
    ): void {
        if (!isPrimaryPointer(e)) {
            return;
        }

        activeDrag.value = target;
        activePointerId = e.pointerId;

        areaRef.setPointerCapture(e.pointerId);
        updateHandler(e);

        window.addEventListener("pointermove", onPointerMove, { passive: false });
        window.addEventListener("pointerup", onStopPointerDrag, { passive: true });
        window.addEventListener("pointercancel", onStopPointerDrag, { passive: true });
    }


    // #endregion Functions

    // #region Event Handlers

    function onSelectClick(): void {
        commitSelection();
    }

    function onCancelClick(): void {
        cancelSelection();
    }

    function onBlur(): void {
        isTyping.value = false;

        if (!props.modelModifiers?.hex) {
            return;
        }

        const trimmed = displayValue.value.trim();
        if (!trimmed) {
            return;
        }

        const hex = normalizeToHex(trimmed);
        if (!hex) {
            return;
        }

        if (displayValue.value !== hex) {
            displayValue.value = hex;
            emit("update:modelValue", hex);
        }

        currentFormat.value = "hex";
        syncFromHex(hex);
    }

    function onStartSVDrag(e: PointerEvent): void {
        if (svArea.value) {
            beginDrag(e, "sv", svArea.value, onUpdateSV);
        }
    }

    function onStartHueDrag(e: PointerEvent): void {
        if (hueArea.value) {
            beginDrag(e, "hue", hueArea.value, onUpdateHue);
        }
    }

    function onStartAlphaDrag(e: PointerEvent): void {
        if (alphaArea.value) {
            beginDrag(e, "alpha", alphaArea.value, onUpdateAlpha);
        }
    }

    function onPointerMove(e: PointerEvent): void {
        // If another finger touches the screen, ignore it
        if (activePointerId === null || e.pointerId !== activePointerId) {
            return;
        }

        // Prevent scrolling while dragging (works with passive: false)
        e.preventDefault();

        switch (activeDrag.value) {
            case "sv":
                onUpdateSV(e);
                break;
            case "hue":
                onUpdateHue(e);
                break;
            case "alpha":
                onUpdateAlpha(e);
                break;
        }
    }

    function onUpdateAlpha(e: PointerEvent): void {
        if (!alphaArea.value) {
            return;
        }

        const rect = alphaArea.value.getBoundingClientRect();
        const y = Math.max(0, Math.min(e.clientY - rect.top, rect.height));

        const raw = 1 - (y / rect.height);
        alpha.value = Math.min(1, Math.max(0, Math.round(raw * 100) / 100));

        updateFromHsv();
    }

    function onStopPointerDrag(e: PointerEvent): void {
        if (activePointerId === null || e.pointerId !== activePointerId) {
            return;
        }

        switch (activeDrag.value) {
            case "sv":
                svArea.value?.releasePointerCapture(e.pointerId);
                break;
            case "hue":
                hueArea.value?.releasePointerCapture(e.pointerId);
                break;
            case "alpha":
                alphaArea.value?.releasePointerCapture(e.pointerId);
                break;
        }

        activeDrag.value = null;
        activePointerId = null;

        window.removeEventListener("pointermove", onPointerMove);
        window.removeEventListener("pointerup", onStopPointerDrag);
        window.removeEventListener("pointercancel", onStopPointerDrag);
    }

    function onUpdateSV(e: PointerEvent): void {
        if (!svArea.value) {
            return;
        }

        const rect = svArea.value.getBoundingClientRect();
        const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
        const y = Math.max(0, Math.min(e.clientY - rect.top, rect.height));

        saturation.value = Math.round((x / rect.width) * 100);
        value.value = Math.round(100 - (y / rect.height) * 100);

        updateFromHsv();
    }

    function onUpdateHue(e: PointerEvent): void {
        if (!hueArea.value) {
            return;
        }

        const rect = hueArea.value.getBoundingClientRect();
        const y = Math.max(0, Math.min(e.clientY - rect.top, rect.height));

        const raw = 360 - (y / rect.height) * 360;
        hue.value = clamp(Math.round(raw), 0, 360);

        updateFromHsv();
    }

    function onSelectPalette(base: string): void {
        const hex = normalizeToHex(base);
        if (!hex) {
            return;
        }

        displayValue.value = formatHexForOutput(hex);

        syncFromHex(hex);
    }

    function onSelectSwatch(color: string): void {
        const hex = normalizeToHex(color);
        if (!hex) {
            return;
        }

        displayValue.value = formatHexForOutput(hex);

        syncFromHex(hex);
    }

    function onViewportChange(): void {
        if (isOpen.value) {
            updatePopoverPosition();
        }
    }

    function onPopoverButtonClick(): void {
        isOpen.value = !isOpen.value;
    }

    function onClickOutside(e: PointerEvent): void {
        if (!isOpen.value) {
            // Skip if not open.
            return;
        }

        if (popover.value && popover.value.contains(e.target as Node)) {
            // Avoid closing the popover when clicking inside it.
            return;
        }

        if (popoverButton.value && popoverButton.value.contains(e.target as Node)) {
            // Avoid closing the popover when clicking the button that toggles it.
            // That button has its own click handler that will close/open the popover.
            return;
        }


        if (isElement(e.target) && e.target.closest(".tooltip")) {
            // Avoid closing the popover when interacting with tooltips.
            return;
        }

        cancelSelection();
    }

    // #endregion Event Handlers

    // #region Watchers

    watch(popover, () => {
        if (popover.value && isOpen.value) {
            requestAnimationFrame(updatePopoverPosition);
        }
    });

    watch(() => props.modelValue, (newValue) => {
        if (isTyping.value) {
            return;
        }

        const trimmed = newValue?.trim() ?? "";

        const hex = normalizeToHex(trimmed);

        if (props.modelModifiers?.hex) {
            if (hex) {
                displayValue.value = hex;
                currentFormat.value = "hex";
                syncFromHex(hex);
            }
            else {
                displayValue.value = trimmed;
                currentFormat.value = null;
            }

            return;
        }

        // Non-hex mode
        displayValue.value = trimmed;
        currentFormat.value = detectFormat(trimmed);

        if (hex) {
            syncFromHex(hex);
        }
    });

    watch(displayValue, (newValue) => {
        if (!isTyping.value) {
            return;
        }

        const trimmed = newValue?.trim() ?? "";

        const detected = detectFormat(trimmed);
        if (detected) {
            currentFormat.value = detected;
        }

        const hex = normalizeToHex(trimmed);
        if (hex) {
            syncFromHex(hex);
        }

        if (!isOpen.value) {
            emit("update:modelValue", trimmed);
        }
    });

    watch(isOpen, async (open) => {
        if (!open) {
            // Reset the simple/advanced view when closing the popover to ensure the palette is always shown first when reopening.
            isAdvancedViewVisible.value = false;
            document.removeEventListener("pointerdown", onClickOutside);
            return;
        }

        document.addEventListener("pointerdown", onClickOutside);
        openBaselineValue.value = props.modelValue ?? "";

        const hex = normalizeToHex(displayValue.value ?? "");

        if (!hex) {
            isAdvancedViewVisible.value = false;
        }
        else {
            // If no matching simple swatch exists, show advanced view.
            isAdvancedViewVisible.value = selectedSimpleViewSwatchItem.value === null;
        }

        await nextTick();
        requestAnimationFrame(updatePopoverPosition);
    });

    watch(
        () => props.modelModifiers?.hex,
        (isHexEnabled) => {
            if (isHexEnabled) {
                currentFormat.value = "hex";

                const hex = normalizeToHex(displayValue.value);
                if (hex) {
                    displayValue.value = hex;
                    emit("update:modelValue", hex);
                    syncFromHex(hex);
                }
            }
            else {
                // Restore format detection from current display value
                currentFormat.value = detectFormat(displayValue.value);

                const hex = normalizeToHex(displayValue.value);
                if (hex) {
                    syncFromHex(hex);
                }
            }
        }
    );

    // #endregion Watchers

    // #region Hooks

    onMounted(async () => {
        window.addEventListener("resize", onViewportChange);
        window.addEventListener("scroll", onViewportChange, true);

        const initial = displayValue.value;
        const hex = normalizeToHex(initial);

        if (props.modelModifiers?.hex) {
            currentFormat.value = "hex";

            if (hex && initial !== hex) {
                displayValue.value = hex;
                emit("update:modelValue", hex);
            }
        }
        else {
            // Preserve original format
            currentFormat.value = detectFormat(initial);
        }

        if (hex) {
            syncFromHex(hex);
        }

        const colors = await loadColorSwatches();
        definedValueSwatchItems.value = Enumerable
            .from(colors)
            .where(c => !!c.value)
            .select<SwatchItemWithLocation>(c => {
                return {
                    ...createSwatchItem(c.description ?? c.value!, c.value!),
                    displayLocation: c.displayLocation === "Palette Color" ? "Palette Color" : "Custom"
                };
            })
            .toArray();
    });

    onUnmounted(() => {
        window.removeEventListener("pointermove", onPointerMove);
        window.removeEventListener("pointerup", onStopPointerDrag);
        window.removeEventListener("pointercancel", onStopPointerDrag);

        window.removeEventListener("resize", onViewportChange);
        document.removeEventListener("pointerdown", onClickOutside);
        window.removeEventListener("scroll", onViewportChange, true);
    });

    // #endregion Hooks
</script>
