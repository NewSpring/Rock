<template>
    <RockFormField :modelValue="modelValue"
                   v-bind="standardFieldProps"
                   formGroupClasses="rock-color-picker"
                   name="colorpicker">
        <template #default="{ uniqueId, field }">
            <div class="control-wrapper"
                 :style="{ '--color': displayValue }">
                <slot name="prepend"
                      :isInputGroupSupported="true"></slot>

                <div ref="colorPicker"
                     class="input-group input-width-lg">
                    <slot name="inputGroupPrepend"
                          :isInputGroupSupported="true"></slot>

                    <input v-model="displayValue"
                           :id="uniqueId"
                           type="text"
                           class="form-control"
                           v-bind="field"
                           :placeholder="placeholder"
                           @focus="isTyping = true"
                           @blur="onBlur" />
                    <span class="input-group-addon color-preview-wrapper"
                          :class="{ 'is-selected': isOpen }"
                          ref="popoverButton"
                          @click="onPopoverButtonClick()">
                        <span class="color-preview"></span>
                    </span>

                    <slot name="inputGroupAppend"
                          :isInputGroupSupported="true"></slot>

                    <teleport to="body">
                        <div v-if="isOpen && !isAdvancedViewVisible"
                             ref="popover"
                             class="picker-popover picker-popover-simple"
                             :style="popoverStyle"
                             @pointerdown.stop>
                            <div class="picker-popover-body">
                                <div class="swatch-list-form-group">
                                    <div class="swatch-list-label">Palette</div>
                                    <div class="swatch-list-group">
                                        <div v-for="(chunk, index) in chunkedDefaultSwatches"
                                             :key="index"
                                             class="swatch-list">
                                            <div v-for="(s, subIndex) in chunk"
                                                 :key="subIndex"
                                                 class="swatch"
                                                 :class="{ 'is-selected': selectedSimpleViewSwatchItem?.color === s.color, 'has-border': s.isBorderRequired }"
                                                 :style="{ background: s.color }"
                                                 v-tooltip.html="getTooltipContent(s.name, s.color)"
                                                 @click="onSelectPalette(s.color)">
                                            </div>
                                        </div>
                                        <div class="swatch-list">
                                            <div v-for="(s, index) in definedValuePaletteColorSwatchItems"
                                                 :key="index"
                                                 class="swatch"
                                                 :class="{ 'is-selected': selectedSimpleViewSwatchItem?.color === s.color, 'has-border': s.isBorderRequired }"
                                                 :style="{ background: s.color }"
                                                 v-tooltip.html="getTooltipContent(s.name, s.color)"
                                                 @click="onSelectPalette(s.color)">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div v-if="selectedSimpleViewSwatchItem?.shades"
                                     class="swatch-list-form-group">
                                    <div class="swatch-list-label">{{ selectedSimpleViewSwatchItem.name }} Shades</div>
                                    <div class="swatch-list">
                                        <div v-for="(shade, index) in selectedSimpleViewSwatchItem?.shades"
                                             :key="index"
                                             class="swatch"
                                             :class="{ 'is-selected': isSwatchSelected(shade), 'has-border': shade.isBorderRequired }"
                                             :style="{ background: shade.color }"
                                             v-tooltip.html="getTooltipContent(shade.name, shade.color)"
                                             @click="onSelectSwatch(shade.color)">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="picker-popover-footer">
                                <div class="picker-actions">
                                    <div class="picker-commit-actions">
                                        <RockButton btnType="primary"
                                                    btnSize="sm"
                                                    type="button"
                                                    @click="onSelectClick">
                                            Select
                                        </RockButton>

                                        <RockButton btnType="link"
                                                    btnSize="sm"
                                                    type="button"
                                                    @click="onCancelClick">
                                            Cancel
                                        </RockButton>
                                    </div>

                                    <RockButton btnSize="sm"
                                                isSquare
                                                title="Switch to Advanced View"
                                                @click="isAdvancedViewVisible = true">
                                        <i class="ti ti-palette"></i>
                                    </RockButton>
                                </div>
                            </div>
                        </div>
                        <div v-if="isOpen && isAdvancedViewVisible"
                             ref="popover"
                             class="picker-popover picker-popover-advanced"
                             :style="popoverStyle"
                             @pointerdown.stop>
                            <div class="picker-popover-body">
                                <div class="picker-row">
                                    <div ref="svArea"
                                         class="sv-area"
                                         :style="svStyle"
                                         @pointerdown="onStartSVDrag">
                                        <div class="sv-indicator"
                                             :style="svIndicatorStyle"></div>
                                    </div>

                                    <div ref="hueArea"
                                         class="hue-slider"
                                         @pointerdown="onStartHueDrag">
                                        <div class="hue-indicator"
                                             :style="hueIndicatorStyle"></div>
                                    </div>

                                    <div ref="alphaArea"
                                         class="alpha-slider"
                                         :style="alphaStyle"
                                         @pointerdown="onStartAlphaDrag">
                                        <div class="alpha-indicator"
                                             :style="alphaIndicatorStyle"></div>
                                    </div>

                                </div>

                                <div class="color-preview-bar"
                                     :style="previewStyle">
                                </div>

                                <div class="swatch-list">
                                    <div v-for="(s, index) in definedValueCustomSwatchItems"
                                         :key="index"
                                         class="swatch"
                                         :class="{ 'is-selected': isSwatchSelected(s) }"
                                         :style="{ background: s.color }"
                                         v-tooltip.html="getTooltipContent(s.name, s.color)"
                                         @click="onSelectSwatch(s.color)">
                                    </div>
                                </div>
                            </div>

                            <div class="picker-popover-footer">
                                <div class="picker-actions">
                                    <div class="picker-commit-actions">
                                        <RockButton btnType="primary"
                                                    btnSize="sm"
                                                    type="button"
                                                    @click="onSelectClick">
                                            Select
                                        </RockButton>

                                        <RockButton btnType="link"
                                                    btnSize="sm"
                                                    type="button"
                                                    @click="onCancelClick">
                                            Cancel
                                        </RockButton>
                                    </div>

                                    <RockButton btnSize="sm"
                                                btnType="default"
                                                class="active focus"
                                                isSquare
                                                title="Switch to Simple View"
                                                @click="isAdvancedViewVisible = false">
                                        <i class="ti ti-palette"></i>
                                    </RockButton>
                                </div>
                            </div>
                        </div>
                    </teleport>
                </div>

                <slot name="append"
                      :isInputGroupSupported="true"></slot>
            </div>
        </template>
    </RockFormField>
</template>

<style scoped>
.color-preview-wrapper {
    padding: 7px var(--spacing-small);
    cursor: pointer;
}

.color-preview-wrapper.is-selected {
    border: 1px solid var(--color-primary);
    outline: none;
}

.color-preview {
    width: 20px;
    height: 20px;
    aspect-ratio: 1/1;
    border-radius: 6px;
    border: 1px solid var(--color-interface-soft);
    display: block;
    background: var(--color);
}

.picker-popover {
    --alpha-square-size: 7px;
    --alpha-slider-squares-across: 3;
    --vertical-slider-width: calc(var(--alpha-square-size) * var(--alpha-slider-squares-across));
    --area-section-gap: var(--spacing-xsmall);
    /* --area-section-width: calc(var(--sv-area-size) + var(--area-section-gap) + var(--vertical-slider-width) + var(--area-section-gap) + var(--vertical-slider-width)); */
    --area-section-width: calc((var(--swatch-horizontal-count) * var(--swatch-size)) + ((var(--swatch-horizontal-count) - 1) * var(--swatch-horizontal-gap)));
    --sv-area-size: calc(var(--area-section-width) - (var(--area-section-gap) * 2) - (var(--vertical-slider-width) * 2));
    --preview-bar-squares-across: 2;
    --preview-bar-height: calc(var(--alpha-square-size) * var(--preview-bar-squares-across));
    --background-color: var(--color-interface-softest);

    position: fixed;
    display: flex;
    flex-direction: column;
    /* Use the same z-index as other dropdowns in Rock */
    z-index: 1050;
    background: var(--background-color);
    border: 1px solid var(--color-interface-soft);
    border-radius: var(--rounded-small);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    overflow: hidden;
}

.picker-popover-simple {
    --swatch-horizontal-count: v-bind(SIMPLE_VIEW_SWATCHES_PER_ROW);
    --swatch-size: 20px;
    --swatch-horizontal-gap: var(--spacing-tiny);

}

.picker-popover-advanced {
    --swatch-horizontal-count: v-bind(ADVANCED_VIEW_SWATCHES_PER_ROW);
    --swatch-size: 28px;
    --swatch-horizontal-gap: var(--spacing-xsmall);
}

.picker-popover-body {
    display: flex;
    flex-direction: column;
    gap: var(--area-section-gap);
    padding: var(--spacing-medium);
}

.picker-popover-footer {
    padding: var(--spacing-small);
    border-top: 1px solid var(--color-interface-soft);
    background: var(--color-interface-softer);
}

.picker-actions {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
}

.picker-commit-actions {
    display: flex;
    flex-direction: row;
    gap: var(--spacing-small);
}

.picker-row {
    display: flex;
    flex-direction: row;
    gap: var(--area-section-gap);
}

.sv-area {
    position: relative;
    width: var(--sv-area-size);
    height: var(--sv-area-size);
    cursor: crosshair;
    user-select: none;
    touch-action: none;
}

.hue-slider {
    position: relative;
    width: var(--vertical-slider-width);
    height: var(--sv-area-size);
    background: linear-gradient(to top,
            red,
            yellow,
            lime,
            cyan,
            blue,
            magenta,
            red);
    cursor: ns-resize;
    user-select: none;
    touch-action: none;
}

.alpha-slider {
    position: relative;
    width: var(--vertical-slider-width);
    height: var(--sv-area-size);
    cursor: ns-resize;
    user-select: none;
    touch-action: none;
}

.alpha-indicator {
    position: absolute;
    left: 0;
    right: 0;
    height: 4px;
    background: white;
    box-shadow: 0 0 2px rgba(0, 0, 0, 0.8);
}

.sv-indicator {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 0 2px rgba(0, 0, 0, 0.8);
    transform: translate(-50%, -50%);
}

.hue-indicator {
    position: absolute;
    left: 0;
    right: 0;
    height: 4px;
    background: white;
    box-shadow: 0 0 2px rgba(0, 0, 0, 0.8);
}

.color-preview-bar {
    height: var(--preview-bar-height);
    max-width: var(--area-section-width);
}

.swatch-list-form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xsmall);
}

.swatch-list-label {
    color: var(--color-interface-medium);
    font-size: var(--font-size-xsmall);
}

.swatch-list {
    display: flex;
    flex-direction: row;
    gap: var(--area-section-gap);
    max-width: var(--area-section-width);
    flex-wrap: wrap;
    overflow: visible;
}

.picker-popover-simple .swatch-list {
    gap: var(--spacing-tiny);
}

.swatch-list-group {
    display: flex;
    flex-direction: column;
    /* Use the same gap that is used between swatch items so swatch lists appear continuous */
    gap: var(--area-section-gap);
}

.swatch {
    width: 28px;
    height: 28px;
    aspect-ratio: 1/1;
    border-radius: var(--rounded-small);
    cursor: pointer;

    --scale: 1;

    will-change: transform;
    transform: scale(var(--scale));
    transform-origin: center;

    transition: transform 200ms ease-in-out;
}

.picker-popover-simple .swatch {
    width: 20px;
    height: 20px;
}

.swatch.is-selected {
    border: 1px solid var(--color-interface-softest);
    box-shadow: 0 0 4px 0 var(--color-primary);
}

.swatch.has-border:not(.is-selected) {
    border: 1px solid var(--color-interface-soft);
}

.swatch:hover {
    --scale: 1.2;
    z-index: 1;
}
</style>

<script setup lang="ts">
    import { computed, nextTick, onMounted, onUnmounted, PropType, ref, watch } from "vue";
    import RockFormField from "./rockFormField.obs";
    import { standardRockFormFieldProps, useStandardRockFormFieldProps } from "@Obsidian/Utility/component";
    import { ColorPickerSwatchBag } from "@Obsidian/ViewModels/Rest/Controls/colorPickerSwatchBag";
    import { ColorPickerGetColorPickerSwatchesOptionsBag } from "@Obsidian/ViewModels/Rest/Controls/colorPickerGetColorPickerSwatchesOptionsBag";
    import { vTooltip } from "@Obsidian/Directives/tooltip";
    import RockButton from "@Obsidian/Controls/rockButton.obs";
    import { RockColor } from "@Obsidian/Core/Utilities/rockColor";
    import { useHttp } from "@Obsidian/Utility/http";
    import { Enumerable } from "@Obsidian/Utility/linq";
    import { isElement } from "@Obsidian/Utility/dom";

    type ColorFormat = "hex" | "rgb" | "named";
    type ShadeStop = "50" | "100" | "200" | "300" | "400" | "500" | "600" | "700" | "800" | "900" | "950";

    /** Represents a color swatch item that can be displayed in the color picker */
    type SwatchItem = {
        name: string;
        color: string;
        normalizedHex: string;
        shades?: ShadeSwatchItem[];
        isBorderRequired: boolean;
    };

    /** Represents a shade swatch item that can be displayed in the color picker */
    type ShadeSwatchItem = Omit<SwatchItem, "shades"> & {
        stop: string;
    };

    type SwatchItemWithLocation = SwatchItem & {
        displayLocation: "Palette Color" | "Custom";
    };

    type DragTarget = "sv" | "hue" | "alpha";

    const props = defineProps({
        modelValue: {
            type: String as PropType<string>,
            required: true
        },

        placeholder: {
            type: String as PropType<string>,
            default: ""
        },

        modelModifiers: {
            type: Object as PropType<{ hex?: boolean } | undefined>
        },
        ...standardRockFormFieldProps
    });

    const emit = defineEmits<{
        (e: "update:modelValue", value: string): void;
    }>();

    const http = useHttp();
    const standardFieldProps = useStandardRockFormFieldProps(props);

    let shadowHost: HTMLElement | null = null;
    let shadowProbe: HTMLElement | null = null;

    // eslint-disable-next-line @typescript-eslint/naming-convention
    const MIN_SWATCH_CONTRAST = 1.2;
    // eslint-disable-next-line @typescript-eslint/naming-convention
    const SIMPLE_VIEW_SWATCHES_PER_ROW = 11;
    // eslint-disable-next-line @typescript-eslint/naming-convention
    const ADVANCED_VIEW_SWATCHES_PER_ROW = 7;

    const backgroundColorCssVariable = "--color-interface-softest";
    const popupBg = new RockColor(getComputedStyle(document.documentElement).getPropertyValue(backgroundColorCssVariable));

    let activePointerId: number | null = null;

    // From https://tailwindcss.com/docs/colors
