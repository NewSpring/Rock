<!-- Copyright by the Spark Development Network; Licensed under the Rock Community License -->
<template>
    <ComponentPropertyPanelBase :componentElement="componentElement"
                                :hasPaddedBody="true"
                                :ltr="ltr"
                                title="Lava"
                                @clone="$emit('clone')"
                                @complete="$emit('complete')"
                                @delete="$emit('delete')"
                                @migrate="$emit('migrate', $event)">
        <div class="row">
            <div class="col-sm-12">
                <CodeEditor v-model="html"
                            mode="lava" />
            </div>
        </div>

        <div class="row">
            <div class="col-sm-12">
                <p class="text-muted text-sm mb-3">
                    *Keep in mind: Most email clients do not support interactive elements like JavaScript or Flash. Use basic HTML for higher likelihood of compatibility
                </p>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-12">
                <ShorthandPixelBox v-model="marginPx"
                                   label="Margin" />
            </div>
        </div>
    </ComponentPropertyPanelBase>
</template>

<script setup lang="ts">
    import { onMounted, onUnmounted, PropType, ref, watch } from "vue";
    import ComponentPropertyPanelBase from "./componentPropertyPanelBase.partial.obs";
    import ShorthandPixelBox from "../shorthandPixelBox.partial.obs";
    import { ShorthandModel, UsageType } from "../types.partial";
    import {
        addRockContentEditableEventListener,
        codeComponentAdapter,
        removeRockContentEditableEventListener
    } from "../utils.partial";
    import CodeEditor from "@Obsidian/Controls/codeEditor.obs";

    const props = defineProps({
        componentElement: {
            type: Object as PropType<HTMLElement>,
            required: true
        },

        ltr: {
            type: Boolean as PropType<boolean>,
            default: false
        },

        mergeFields: {
            type: Object as PropType<string[] | null | undefined>,
            required: false
        },

        usageType: {
            type: String as PropType<UsageType>,
            default: "email" as const
        }
    });

    defineEmits<{
        (e: "clone"): void;
        (e: "complete"): void;
        (e: "delete"): void;
        (e: "migrate", value: Element): void;
    }>();

    // #region Values

    const html = ref<string>("");
    const marginPx = ref<ShorthandModel<number | null> | null>(null);

    // #endregion Values

    // #region Functions

    function readProps(): void {
        const localProps = codeComponentAdapter.readLocalProps(props.componentElement);
        html.value = localProps.html;
        marginPx.value = localProps.marginPx;
    }

    function writeProps(): void {
        codeComponentAdapter.writeLocalProps(props.componentElement, {
            html: html.value,
            marginPx: marginPx.value
        });
    }

    // #endregion Functions

    // #region Event Handlers

    function onInput(): void {
        const { html: enteredHtml } = codeComponentAdapter.readLocalProps(props.componentElement);
        html.value = enteredHtml;
    }

    // #endregion Event Handlers

    // #region Watchers

    // Handle html changes separately to avoid double-writing
    // when the user is editing the content of the element itself.
    watch(html, (newValue) => {
        const { html: currentHtml } = codeComponentAdapter.readLocalProps(props.componentElement);

        if (currentHtml !== newValue) {
            writeProps();
        }
    });

    watch(() => props.componentElement, (newComponentElement, oldComponentElement) => {
        readProps();

        removeRockContentEditableEventListener(oldComponentElement, onInput);
        addRockContentEditableEventListener(newComponentElement, onInput);
    });

    watch([marginPx], () => { // html changes are handled in their own watcher above
        writeProps();
    });

    // #endregion Watchers

    // #region Hooks

    onMounted(() => {
        readProps();
        addRockContentEditableEventListener(props.componentElement, onInput);
    });

    onUnmounted(() => {
        removeRockContentEditableEventListener(props.componentElement, onInput);
    });

    // #endregion Hooks
</script>
