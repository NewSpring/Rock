    }

    /**
     * Called when the individual changes which rows are selected.
     *
     * @param state The state object that describes the grid.
     */
    function onSelectedKeysChanged(key: string | null | undefined, state: IGridState): void {
        if (!key) {
            return;
        }
        selectedKeys.value[key] = [...state.selectedKeys];
    }

