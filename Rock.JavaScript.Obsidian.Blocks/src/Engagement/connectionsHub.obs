        isSendEmailModalVisible.value = true;
    }

    function clearAllSelections() {
        console.log("clearing: ", groupedGridPanel.value);
        groupedGridPanel.value.clearSelectedKeys();
        // gridRefs.value.forEach(grid => {
        //     console.log("clearning for grid: ", grid);
        //     grid.clearSelectedKeys();
        // });
