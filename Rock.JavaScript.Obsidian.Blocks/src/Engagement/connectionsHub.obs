    function updateStatusFromModal(bag: ConnectionRequestUpdateBag): void {
        const statusUpdateBags: ConnectionRequestUpdateBag[] = [];
        const completedRequests: string[] = [];

        if (box.options?.isSequentialStatusMode) {
            const statusIndexByGuid = new Map(
                connectionStatusItems.value.map((s, i) => [s.value, i])
            );

            const lastStatusIndex = connectionStatusItems.value.length - 1;


            for (const request of selectedRequestDetails.value) {
                const currentIndex = statusIndexByGuid.get(request.connectionStatus?.guid);
                if (currentIndex === undefined || isNullOrWhiteSpace(request.idKey)) {
                    continue;
                }

                // Last sequential status then update state to Connected
                if (currentIndex === lastStatusIndex) {
                    completedRequests.push(request.idKey!);
                    continue;
                }

                // Otherwise next sequential status
                const nextStatus = connectionStatusItems.value[currentIndex + 1];

                statusUpdateBags.push({
                    connectionRequestIdKey: request.idKey,
                    connectionStatusGuid: nextStatus.value,
                    note: bag.note
                });
            }
        }
        else {
            for (const key of allSelectedKeys.value) {
                statusUpdateBags.push({
                    connectionRequestIdKey: key,
                    connectionStatusGuid: bag.connectionStatusGuid,
                    note: bag.note
                });
            }
        }

        updateRequestStatuses(statusUpdateBags, completedRequests);
    }

