<!-- Copyright by the Spark Development Network; Licensed under the Rock Community License -->
<template>
    <ContextSlicer title="Filters"
                   class="mb-spacing-lg"
                   showCampus>
        <template #default>
            <DropDownList v-model="areOnlyMyRequestsVisible"
                          :items="requestToggleItems"
                          :showBlankItem="false" />
            <DropDownList v-model="selectedOpportunity"
                          :items="box.options?.connectionOpportunities ?? []"
                          blankValue="All Opportunities" />
        </template>
    </ContextSlicer>

    <GroupedGridPanel v-model:quickFilterValue="rawQuickFilter"
                      v-model:groupingKey="selectedGrouping"
                      v-model:orderedRequestKeys="orderedRequestKeys"
                      ref="groupedGridPanel"
                      :title="box.options?.title ?? ''"
                      :titleIconCssClass="`${box.options?.iconCssClass ?? ''} panel-icon`"
                      :isSelectedView="hasAnySelectedKeys"
                      :rows="gridData?.rows ?? []"
                      :filteredAndSortedRows="visibleRows"
                      :panelSettingsActive="hasSettingsFilters"
                      :groupingFields="groupingFields"
                      itemTerm="Request"
                      hasFullscreen
                      :onAddItem="onAddItem"
                      :onPanelSettingsClick="onPanelSettingsClick"
                      :headerSecondaryActions="secondaryActions">
        <template #selectedActionToolbar>
            <div class="left-actions d-flex align-items-center gap-md">
                <div class="d-flex align-items-center gap-tiny">
                    <RockLabel class="text-info-strong mb-0">Selected</RockLabel>
                    <Badge class="font-weight-semibold bg-info-strong">{{ allSelectedKeys.length }}</Badge>
                </div>
                <div class="d-flex align-items-center gap-xs">
                    <RockButton class="activity-btn" @click="showAssignRequestModal">
                        <i class="ti ti-user-circle"></i>
                        <span class="activity-btn-label">Assign</span>
                    </RockButton>
                    <RockButton @click="showChangeStatusModal" class="activity-btn">
                        <template v-if="box.options?.isSequentialStatusMode">
                            <i class="ti ti-arrow-right"></i>
                            <span class="activity-btn-label">Advance to Next Status</span>
                        </template>
                        <template v-else>
                            <i class="ti ti-select"></i>
                            <span class="activity-btn-label">Change Status</span>
                        </template>
                    </RockButton>
                    <RockButton @click="showLaunchWorkflowModal()" class="activity-btn">
                        <i class="ti ti-settings-cog"></i>
                        <span class="activity-btn-label">Launch Workflow</span>
                    </RockButton>
                    <RockButton class="activity-btn" @click="showChangeStateModal(ConnectionState.Connected)">
                        <i class="ti ti-circle-check"></i>
                        <span class="activity-btn-label">Complete</span>
                    </RockButton>
                    <div class="dropdown">
                        <i class="ti ti-dots-vertical cursor-pointer" data-toggle="dropdown"></i>
                        <ul class="dropdown-menu">
                            <li>
                                <button type="button"
                                        @click="showChangeStateModal(ConnectionState.Active)"
                                        class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                    <i class="ti ti-user pr-spacing-sm text-interface-medium"></i>Set as Active
                                </button>
                            </li>
                            <li>
                                <button type="button"
                                        @click="showChangeStateModal(ConnectionState.Inactive)"
                                        class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                    <i class="ti ti-user-off pr-spacing-sm text-interface-medium"></i>Set as Inactive
                                </button>
                            </li>
                            <li v-if="box.options?.isFutureFollowUpEnabled">
                                <button type="button"
                                        @click="showChangeStateModal(ConnectionState.FutureFollowUp)"
                                        class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                    <i class="ti ti-calendar pr-spacing-sm text-interface-medium"></i>Set as Future Follow-Up
                                </button>
                            </li>
                            <li>
                                <button type="button"
                                        @click="showDeleteRequestModal()"
                                        class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold text-danger">
                                    <i class="ti ti-trash pr-spacing-sm text-danger"></i>Delete
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="right-actions d-flex align-items-center gap-md">
                <div class="pl-spacing-md d-flex align-items-center gap-xs">
                    <RockButton @click="showSMSModal()" class="activity-btn">
                        <i class="ti ti-message-circle-plus"></i>
                        <span class="activity-btn-label">SMS</span>
                    </RockButton>
                    <RockButton @click="showEmailModal()" class="activity-btn">
                        <i class="ti ti-mail-plus"></i>
                        <span class="activity-btn-label">Email</span>
                    </RockButton>
                </div>
                <div class="border-left border-info pl-spacing-md d-flex align-items-center gap-md">
                    <RockButton class="activity-btn" @click="showAddActivityModal">
                        <i class="ti ti-activity"></i>
                        <span class="activity-btn-label">Add Activity</span>
                    </RockButton>
                    <div class="d-flex align-items-center gap-sm">
                        <i class="ti ti-x cursor-pointer" @click="clearAllSelections"></i>
                    </div>
                </div>
            </div>
        </template>
        <template #headerActions="{ groupRows }" v-if="selectedGrouping !== 'dueStatusGrouping'">
            <HighlightLabel labelType="warning">
                {{ getDueSoonCount(groupRows) }} Due Soon
            </HighlightLabel>
            <HighlightLabel labelType="danger">
                {{ getOverdueCount(groupRows) }} Overdue
            </HighlightLabel>
        </template>
        <template #grid="{ group, setGridRef }">
            <Grid :definition="box.gridDefinition ?? undefined"
                  :ref="setGridRef"
                  :data="group.gridData"
                  keyField="idKey"
                  :isTitleHidden="true"
                  :isSearchVisible="false"
                  :isFooterHidden="true"
                  :showExport="false"
                  :showMergeTemplate="false"
                  :isCountMessageVisible="false"
                  :hideFilterHeaderRow="true"
                  light
                  :forceVirtualRowsOnLight="true"
                  class="grid-hover"
                  @selectedKeysChanged="state => onSelectedKeysChanged(group.key, state)"
                  @selectItem="onSelectItem">
                <SelectColumn />

                <PersonColumn name="requestDetails"
                              title="Request Details"
                              field="requestDetails" />

                <Column v-if="viewOptions.gridDataToShow?.includes('connectionOpportunity') && selectedGrouping !== 'opportunityGrouping'"
                        name="connectionOpportunity"
                        field="connectionOpportunity">
                    <template #format="{ row }">
                        <div class="d-flex flex-column align-items-start gap-1">
                            <HighlightLabel labelType="custom"
                                            customClass="label-default text-xs text-semibold text-interface-strong">
                                {{ row.connectionOpportunity }}
                            </HighlightLabel>
                            <span v-if="!isNullOrWhiteSpace(row.connectionTypeSource) && viewOptions.isRequestSourceShown"
                                  class="text-small text-interface-medium">
                                {{ row.connectionTypeSource }}
                            </span>
                        </div>
                    </template>
                </Column>

                <Column v-if="selectedGrouping !== 'connectorGrouping'"
                        title="Connector"
                        name="connectorDetails"
                        field="connectorDetails">
                    <template #format="{ row }">
                        {{ row.connectorDetails?.text }}
                    </template>
                </Column>

                <Column v-if="selectedGrouping !== 'campusGrouping'"
                        name="campus"
                        title="Campus"
                        field="campus">
                    <template #format="{ row }">
                        <div v-if="!!row.campus">
                            {{ row.campus }}
                        </div>
                        <div v-else>
                            <i class="ti ti-minus"></i>
                        </div>
                    </template>
                </Column>

                <Column v-if="box.options?.areGroupPlacementsEnabled"
                        name="group"
                        title="Group"
                        field="group">
                    <template #format="{ row }">
                        <div v-if="!!row.group">
                            {{ row.group }}
                        </div>
                        <div v-else>
                            <i class="ti ti-minus"></i>
                        </div>
                    </template>
                </Column>

                <!-- TODO - handle case where no activity. -->
                <Column v-if="viewOptions.gridDataToShow?.includes('activity')"
                        name="activity"
                        title="Activity"
                        field="activity">
                    <template #format="{ row }">
                        <div v-if="!!row.lastActivityDateTime && !!row.activityCount"
                             class="d-flex align-items-center gap-1">
                            <div class="activity-metric activity-date">
                                <i class="ti ti-calendar-month"></i>
                                <span>
                                    {{ getElapsedShortTime(row.lastActivityDateTime) }}
                                </span>
                            </div>
                            <div class="activity-metric activity-count">
                                <i class="ti ti-bolt"></i>
                                <span>
                                    {{ row.activityCount }}
                                </span>
                            </div>
                        </div>
                        <div v-else>
                            <i class="ti ti-minus"></i>
                        </div>
                    </template>
                </Column>

                <Column v-if="viewOptions.gridDataToShow?.includes('dueDate')"
                        name="dueDate"
                        title="Due"
                        field="dueDate"
                        width="2%">
                    <template #format="{ row }">
                        <div v-if="!!row.dueDate" :class="getDueDateColor(row.dueStatus)">
                            {{ formatDueDateShortLabel(row.dueDate) }}
                        </div>
                        <div v-else>
                            <i class="ti ti-minus"></i>
                        </div>
                    </template>
                </Column>

                <AttributeColumns :attributes="attributesToShow" />

                <Column v-if="box.options?.areCelebrationsEnabled"
                        name="celebration"
                        field="celebration"
                        width="52">
                    <template #format="{ row }">
                        <i v-if="isNullOrWhiteSpace(row.celebrationText)"
                           class="ti ti-confetti cursor-pointer"
                           :ref="(el) => addTooltip(el as Element)"
                           data-toggle="tooltip"
                           data-placement="auto"
                           data-container="body"
                           data-original-title="Add Celebration"
                           @click.stop="showCelebrationModal(row)">
                        </i>
                        <i v-else
                           class="ti ti-confetti-filled cursor-pointer text-info-strong"
                           :ref="(el) => addTooltip(el as Element)"
                           data-toggle="tooltip"
                           data-placement="auto"
                           data-container="body"
                           data-original-title="Has Celebration"
                           @click.stop="showCelebrationModal(row)">
                        </i>
                    </template>
                </Column>

                <Column v-if="box.options?.areRemindersEnabled"
                        name="reminder"
                        field="reminder"
                        width="52">
                    <template #format="{ row }">
                        <i v-if="row.reminderCount > 0"
                           class="ti ti-bell-filled cursor-pointer text-info-strong"
                           :ref="(el) => addTooltip(el as Element)"
                           data-toggle="tooltip"
                           data-placement="auto"
                           data-container="body"
                           :data-original-title="`${row.reminderCount} ${pluralize('Reminder', row.reminderCount)}`"
                           @click.stop="showReminderModal(row)">
                        </i>
                        <i v-else
                           class="ti ti-bell cursor-pointer"
                           :ref="(el) => addTooltip(el as Element)"
                           data-toggle="tooltip"
                           data-placement="auto"
                           data-container="body"
                           data-original-title="Add Reminder"
                           @click.stop="showReminderModal(row)">
                        </i>
                    </template>
                </Column>

                <Column name="connectionStatus"
                        field="connectionStatus">
                    <template #format="{ row }">
                        <div class="w-100">
                            <template v-if="row.connectionState === ConnectionState.Active">
                                <ConnectionStatusButton :isSequentialStatusMode="box.options?.isSequentialStatusMode"
                                                        :highlightColor="row.connectionStatus.highlightColor"
                                                        :currentStatusName="row.connectionStatus.name"
                                                        @click.stop="(e) => onStatusClick(row, e)" />
                            </template>
                            <div v-else-if="row.connectionState === ConnectionState.Inactive"
                                 class="text-center text-semibold text-slate">
                                {{ ConnectionStateDescription[ConnectionState.Inactive] }}
                            </div>
                            <div v-else-if="row.connectionState === ConnectionState.FutureFollowUp"
                                 class="text-center text-semibold text-info-strong">
                                {{ ConnectionStateDescription[ConnectionState.FutureFollowUp] }} - {{ asLocaleString(row.followUpDate) }}
                            </div>
                            <div v-else-if="row.connectionState === ConnectionState.Connected"
                                 class="text-center text-semibold text-emerald">
                                {{ ConnectionStateDescription[ConnectionState.Connected] }}
                            </div>
                        </div>
                    </template>
                </Column>

                <Column name="options"
                        field="options"
                        width="52"
                        itemClass="grid-cell-overflow">
                    <template #format="{ row }">
                        <div :class="['dropdown', 'dropdown-right', { 'open': openDropdownIndex === row.idKey }]">
                            <i class="ti ti-dots-vertical cursor-pointer" data-toggle="dropdown" @click.stop="toggleGridRowDropdown(row.idKey)"></i>
                            <ul class="dropdown-menu">
                                <li>
                                    <button type="button"
                                            @click.stop="showChangeStateModal(ConnectionState.Active, row)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                        <i class="ti ti-user pr-spacing-sm text-interface-medium"></i>Set as Active
                                    </button>
                                </li>
                                <li>
                                    <button type="button"
                                            @click.stop="showChangeStateModal(ConnectionState.Inactive, row)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                        <i class="ti ti-user-off pr-spacing-sm text-interface-medium"></i>Set as Inactive
                                    </button>
                                </li>
                                <li v-if="box.options?.isFutureFollowUpEnabled">
                                    <button type="button"
                                            @click.stop="showChangeStateModal(ConnectionState.FutureFollowUp, row)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                        <i class="ti ti-calendar pr-spacing-sm text-interface-medium"></i>Set as Future Follow-Up
                                    </button>
                                </li>
                                <li>
                                    <button type="button"
                                            @click.stop="showChangeStateModal(ConnectionState.Connected, row)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                        <i class="ti ti-circle-check pr-spacing-sm text-interface-medium"></i>Mark Complete
                                    </button>
                                </li>
                                <li>
                                    <button type="button"
                                            @click.stop="showLaunchWorkflowModal(row)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                        <i class="ti ti-settings-cog pr-spacing-sm text-interface-medium"></i>Launch Workflow
                                    </button>
                                </li>
                                <li v-if="box.options?.isRequestSecurityEnabled">
                                    <button type="button"
                                            @click.stop="showSecurityModal(row.idKey)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold">
                                        <i class="ti ti-lock pr-spacing-sm text-interface-medium"></i>Security
                                    </button>
                                </li>
                                <li>
                                    <button type="button"
                                            @click.stop="showDeleteRequestModal(row)"
                                            class="dropdown-item btn-link py-spacing-xs px-spacing-md font-weight-semibold text-danger">
                                        <i class="ti ti-trash pr-spacing-sm text-danger"></i>Delete
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </template>
                </Column>
            </Grid>
        </template>
    </GroupedGridPanel>

    <ChangeStatusFlyout v-model="isFlyoutOpen"
                        :errorMessage="flyoutErrorMessage"
                        :isCompletionButtonLoading="isFlyoutCompletionButtonLoading"
                        :isSaving="isFlyoutSaving"
                        :anchorEl="anchorEl"
                        :connectionRequestUpdateBag="connectionRequestUpdateBag"
                        :isNoteRequired="isNoteRequired"
                        :isSequentialMode="box.options?.isSequentialStatusMode ?? false"
                        :connectionStatusItems="connectionStatusItems"
                        @updateStatus="changeRequestStatus"
                        @updateState="updateStateFromFlyout"
                        @dismissErrorMessage="flyoutErrorMessage = ''"
                        @close="onFlyoutClose" />

    <AddConnectionRequestModal :modelValue="newConnectionRequest"
                               v-model:visible="isAddConnectionRequestModalVisible"
                               :options="box.options"
                               :connectionOpportunityDetails="connectionOpportunityDetails"
                               :placementGroupDetails="placementGroupDetails"
                               :isConnectionOpportunityFilterSelected="hasSelectedOpportunity"
                               :isExistingActiveRequesterOnConnectionType="isExistingActiveRequesterOnConnectionType"
                               :isSaving="isModalSaving"
                               @checkForActiveRequester="checkForActiveRequester"
                               @save="onAddRequest"
                               @close="resetNewConnectionRequest"
                               @fetchConnectionOpportunityDetails="fetchConnectionOpportunityDetails"
                               @fetchPlacementGroupDetails="fetchPlacementGroupDetails" />

    <AddFromCampaignModal v-model:visible="isAddFromCampaignModalVisible"
                          :selectedOpportunityGuid="selectedOpportunity"
                          :allConnectionOpportunityItems="box.options?.connectionOpportunities ?? []"
                          :isLoading="areCampaignsLoading"
                          :isSaving="isModalSaving"
                          :campaignRecordBags="campaignRecordBags"
                          @assignRequests="assignRequestsFromCampaign" />

    <CelebrationModal v-model:visible="isCelebrationModalVisible"
                      :requestDetails="requestDetailsForModal"
                      :viewOptions="viewOptions"
                      :isSaving="isModalSaving"
                      @upsertCelebration="upsertCelebration" />

    <ReminderModal v-model="isReminderModalVisible"
                   :contextEntityGuid="reminderEntityGuid"
                   :contextEntityTypeGuid="EntityType.PersonAlias"
                   :areDetailsRequired="true"
                   :isAdditionalOptionsLinkVisible="false"
                   @reminderClosed="decreaseReminderCount"
                   @addSuccess="increaseReminderCount">
        <template #postBody>
            <RequestTable :requestDetails="requestDetailsForModal"
                          :viewOptions="viewOptions" />
        </template>
    </ReminderModal>

    <AssignRequestModal v-model:visible="isAssignRequestModalVisible"
                        :connectorItems="allPossibleConnectors"
                        :requestDetails="requestDetailsForModal"
                        :viewOptions="viewOptions"
                        :isSaving="isModalSaving"
                        @updateConnector="updateConnectorFromModal" />
    <ChangeStateModal v-model:visible="isChangeStateModalVisible"
                      :isLoading="areRequestDetailsForModalLoading"
                      :isSaving="isModalSaving"
                      :connectionState="changeStateTo"
                      :requestDetails="requestDetailsForModal"
                      :failingRequestDetails="failingRequestDetailsForModal"
                      :viewOptions="viewOptions"
                      @updateState="updateStateFromModal" />
    <DeleteRequestModal v-model:visible="isDeleteRequestModalVisible"
                        :requestDetails="requestDetailsForModal"
                        :viewOptions="viewOptions"
                        :isSaving="isModalSaving"
                        @deleteRequests="deleteRequestsFromModal" />
    <ActivityModal v-model:visible="isActivityModalVisible"
                   :connectorItems="allPossibleConnectors"
                   :requestDetails="requestDetailsForModal"
                   :connectionActivities="connectionActivityItems ?? []"
                   :viewOptions="viewOptions"
                   :currentPerson="currentPerson"
                   :activityToEdit="activityToEdit"
                   :isSaving="isModalSaving"
                   @upsertActivity="upsertActivity" />
    <ChangeStatusModal v-model:visible="isChangeStatusModalVisible"
                       :connectionStatuses="box.options?.connectionStatuses ?? []"
                       :isSequentialMode="box.options?.isSequentialStatusMode ?? false"
                       :isSaving="isModalSaving"
                       :requestDetails="requestDetailsForModal"
                       :viewOptions="viewOptions"
                       @updateStatus="updateStatusFromModal" />
    <LaunchWorkflowModal v-model:visible="isLaunchWorkflowModalVisible"
                         :workflowItems="box.options?.workflowItems ?? []"
                         :requestDetails="requestDetailsForModal"
                         :viewOptions="viewOptions"
                         :isSaving="isModalSaving"
                         @launchWorkflows="launchWorkflowForRequests" />
    <SendSMSModal v-model:visible="isSendSMSModalVisible"
                  :communicationRecipients="communicationRecipients"
                  :smsFromSystemPhoneNumbers="smsFromSystemPhoneNumbers"
                  :smsSnippets="smsSnippets"
                  @onSuccessfulSend="refreshActivityEntries(dockedPanelDetailsBox?.entity?.connectionRequestIdKey)" />
    <SendEmailModal v-model:visible="isSendEmailModalVisible"
                    :communicationRecipients="communicationRecipients"
                    :communicationTemplates="communicationTemplates"
                    @onSuccessfulSend="refreshActivityEntries(dockedPanelDetailsBox?.entity?.connectionRequestIdKey)" />
    <ViewOptionsModal v-model="viewOptions"
                      v-model:visible="isViewOptionsModalVisible"
                      :gridDataToShowItems="box.options?.gridDataToShowItems ?? []"
                      :connectionStates="box.options?.connectionStates ?? []"
                      :connectionStatuses="box.options?.connectionStatuses ?? []" />

    <ModalAlert v-model="isModalAlertVisible">
        <p>{{ modalAlertText }}</p>
    </ModalAlert>

    <ConnectionRequestDockedPanel v-model="isDockedPanelVisible"
                                  ref="connectionRequestDockedPanelRef"
                                  :currentKey="selectedRequestKey"
                                  :connectionRequestBreadcrumbs="connectionRequestBreadcrumbs"
                                  :orderedKeys="orderedRequestKeys ?? []"
                                  :detailsBox="dockedPanelDetailsBox"
                                  :dockedPanelCloseOnOutsideClick="dockedPanelCloseOnOutsideClick"
                                  :isInSingleRequestMode="isInSingleRequestMode"
                                  @navigate="updateSelectedRequestKey"
                                  @navigateToBreadcrumb="navigateToBreadcrumb"
                                  @navigateToAdditionalRequest="navigateToAdditionalRequest"
                                  @editActivity="onEditActivity"
                                  :isSaving="isDockedPanelSaving"
                                  @editRequest="onEditRequest"
                                  @transferRequest="onTransferClick"
                                  @addActivity="showAddActivityModal"
                                  @onCelebrationClick="box => showCelebrationModal(null, box)"
                                  @onReminderClick="box => showReminderModal(null, box)"
                                  @onSMSClick="showSMSModal(true)"
                                  @onEmailClick="showEmailModal(true)"
                                  @onReassignConnector="(connector) => reassignConnector([dockedPanelDetailsBox?.entity?.connectionRequestIdKey ?? ''], connector, true)"
                                  @onRequestStateChanged="updateRequestStates"
                                  @onStatusButtonClick="onStatusClickFromDockedPanel"
                                  @launchWorkflow="launchWorkflowForRequests"
                                  @deleteRequest="showDeleteRequestModal()" />

    <TransferConnectionRequestModal v-model="isTransferModalVisible"
                                    :transferDetails="transferRequestDetails"
                                    :isSaving="isModalSaving"
                                    @transfer="transferRequest" />
</template>

<style>
/* Temporary fix. See https://app.asana.com/1/20866866924293/project/1208321217019996/task/1212533216082714?focus=true */
.panel-icon {
    color: var(--color-interface-stronger) !important;
}
</style>

<style scoped>
.connection-source {
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-regular);
    color: var(--color-interface-medium);
}

/* The .grid-cell class sets overflow: hidden. This prevens the dropdown menu from working within the cell. This class will set overflow: visible for any grid column with the itemClass "grid-cell-overflow" */
:deep(.grid-cell.grid-cell-overflow) {
    overflow: visible;
}

.activity-metric {
    display: flex;
    align-items: center;
    gap: 2px;
}

.gap-tiny {
    gap: var(--spacing-tiny);
}

.gap-xs {
    gap: var(--spacing-xsmall);
}

.gap-sm {
    gap: var(--spacing-small);
}

.gap-md {
    gap: var(--spacing-medium);
}

.gap-lg {
    gap: var(--spacing-large);
}

.ddl-min-width {
    min-width: 150px;
}

.activity-date {
    color: var(--color-interface-strong);
}

.activity-count {
    color: var(--color-interface-medium);
}

.text-slate {
    color: #64748B;
}

.text-emerald {
    color: #10B981;
}

.dropdown-menu {
    width: 230px;
}

:deep(.dropdown-min-width) {
    min-width: var(--vs-dropdown-min-width);
}

.activity-btn i {
    padding-right: var(--spacing-tiny);
}

@media (max-width: 1290px) {
    .right-actions .activity-btn-label {
        display: none;
    }

    .right-actions .activity-btn i {
        padding: 0;
    }
}

@media (max-width: 1125px) {
    .left-actions .activity-btn-label {
        display: none;
    }

    .left-actions .activity-btn i {
        padding: 0;
    }
}
</style>

<script setup lang="ts">
    import { onConfigurationValuesChanged, useBlockBrowserBus, useConfigurationValues, useInvokeBlockAction, usePersonPreferences, useReloadBlock } from "@Obsidian/Utility/block";
    import { GridDataBag } from "@Obsidian/ViewModels/Core/Grid/gridDataBag";
    import { computed, reactive, ref, watch } from "vue";
    import { ListBlockBox } from "@Obsidian/ViewModels/Blocks/listBlockBox";
    import { ConnectionsHubOptionsBag } from "@Obsidian/ViewModels/Blocks/Engagement/ConnectionsHub/connectionsHubOptionsBag";
    import Grid, { Column, PersonColumn, SelectColumn, AttributeColumns } from "@Obsidian/Controls/grid";
    import { ListItemBag } from "@Obsidian/ViewModels/Utility/listItemBag";
    import DropDownList from "@Obsidian/Controls/dropDownList.obs";
    import HighlightLabel from "@Obsidian/Controls/highlightLabel.obs";
    import GroupedGridPanel from "@Obsidian/Controls/groupedGridPanel.obs";
    import { isNullOrWhiteSpace, pluralize, safeParseJson } from "@Obsidian/Utility/stringUtils";
    import { RockDateTime } from "@Obsidian/Utility/rockDateTime";
    import { tooltip } from "@Obsidian/Utility/tooltip";
    import { DueStatus } from "@Obsidian/Enums/Connection/dueStatus";
    import AddConnectionRequestModal from "./ConnectionsHub/addConnectionRequestModal.partial.obs";
    import { PersonFieldBag } from "@Obsidian/ViewModels/Core/Grid/personFieldBag";
