    }

    function showLaunchWorkflowModal(row: Record<string, unknown> | null = null): void {
        openDropdownIndex.value = null;
        prepareRequestDetailsForModal(row);
        isLaunchWorkflowModalVisible.value = true;
    }

    /**
     * If the docked panel is currently open and we open a modal, we need to disable the "click outside" outside logic on the docked panel.
     * Once the modal is closed we need to enable "click outside" logic again.
     */
    function handleClickOutsideSettingForDockedPanel(value: boolean): void {
        if (isDockedPanelVisible.value) {
            dockedPanelCloseOnOutsideClick.value = value;
        }
    }

    async function updateStatusFromModal(bag: ConnectionRequestUpdateBag): Promise<void> {
        const statusUpdateBags: ConnectionRequestUpdateBag[] = [];
        const completedRequests: string[] = [];

        if (box.options?.isSequentialStatusMode) {
            const statusIndexByGuid = new Map(
                connectionStatusItems.value.map((s, i) => [s.value, i])
            );

            const lastStatusIndex = connectionStatusItems.value.length - 1;


            for (const request of selectedRequestDetails.value) {
                const currentIndex = statusIndexByGuid.get(request.connectionStatus?.guid);
                if (currentIndex === undefined || isNullOrWhiteSpace(request.idKey)) {
                    continue;
                }

                // Last sequential status then update state to Connected
                if (currentIndex === lastStatusIndex) {
                    completedRequests.push(request.idKey!);
                    continue;
                }

                // Otherwise next sequential status
                const nextStatus = connectionStatusItems.value[currentIndex + 1];

                statusUpdateBags.push({
                    connectionRequestIdKey: request.idKey,
                    connectionStatusGuid: nextStatus.value,
                    note: bag.note
                });
            }
        }
        else {
            for (const key of allSelectedKeys.value) {
                statusUpdateBags.push({
                    connectionRequestIdKey: key,
                    connectionStatusGuid: bag.connectionStatusGuid,
                    note: bag.note
                });
            }
        }

        try {
            isModalSaving.value = true;
            await updateRequestStatuses(statusUpdateBags, completedRequests);
        }
        finally {
            isModalSaving.value = false;
        }
    }

    function navigateToBreadcrumb(index: number): void {
        const breadcrumb = connectionRequestBreadcrumbs.value[index];
        if (!breadcrumb.value) {
            return;
        }

        connectionRequestBreadcrumbs.value = connectionRequestBreadcrumbs.value.slice(0, index);
        getConnectionRequestDetails(breadcrumb.value);
    }

    function navigateToAdditionalRequest(connectionRequestIdKey: string): void {
        var currentRequest = dockedPanelDetailsBox.value?.entity;
        if (!currentRequest) {
            return;
        }

        connectionRequestBreadcrumbs.value.push(<ListItemBag>{
            text: `${currentRequest.connectionOpportunityName} (${currentRequest.requesterPerson?.nickName} ${currentRequest.requesterPerson?.lastName})`,
            value: currentRequest.connectionRequestIdKey
        });

        getConnectionRequestDetails(connectionRequestIdKey);
    }

    async function updateStateFromModal(bag: UpdateConnectionRequestStatesBag): Promise<void> {
        try {
            isModalSaving.value = true;
            const errorMessage = await updateRequestStates(bag);

            if (!errorMessage) {
                isChangeStateModalVisible.value = false;

                if (requestDetailsForModal.value.length > 1) {
                    // clear selected keys
                    // TODO - Come back to this after the clear keys bug is fixed.
                    clearAllSelections();
                }
            }
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function updateStateFromFlyout(bag: UpdateConnectionRequestStatesBag): Promise<void> {
        try {
            isFlyoutSaving.value = true;
            const errorMessage = await updateRequestStates(bag);

            if (!errorMessage) {
                isFlyoutOpen.value = false;
            }
            else {
                flyoutErrorMessage.value = errorMessage;
            }
        }
        finally {
            isFlyoutSaving.value = false;
        }
    }

    async function deleteRequestsFromModal(keys: string[]): Promise<void> {
        try {
            isModalSaving.value = true;
            const result = await deleteRequests(keys);

            if (result) {
                isDeleteRequestModalVisible.value = false;
            }
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function showAddFromCampaignModal(): Promise<void> {
        isAddFromCampaignModalVisible.value = true;

        if (!campaignRecordBags.value) {
            areCampaignsLoading.value = true;
            await fetchConnectionCampaigns();
            areCampaignsLoading.value = false;
        }
    }

    function onStatusClick(row: Record<string, unknown>, event: MouseEvent): void {
        const key = row["idKey"] as string | null | undefined;
        const state = row["connectionState"] as ConnectionState | undefined;
        const status = row["connectionStatus"] as ConnectionStatusBag | undefined;
        const hasPlacementGroup = row["hasPlacementGroup"] as boolean | undefined;
        const hasRequiredGroupRequirements = row["hasRequiredGroupRequirements"] as boolean | undefined;

        if (!status
            || !key
            || state === null
            || state === undefined
            || hasPlacementGroup === undefined
            || hasRequiredGroupRequirements === undefined
            || typeof status !== "object"
            || typeof key !== "string"
            || typeof state !== "number"
            || typeof hasPlacementGroup !== "boolean"
            || typeof hasRequiredGroupRequirements !== "boolean") {
            return;
        }

        if (isFlyoutOpen.value && connectionRequestUpdateBag.value.connectionRequestIdKey === key) {
            isFlyoutOpen.value = false;
            return;
        }

        connectionRequestUpdateBag.value = {
            connectionRequestIdKey: key,
            connectionStatusGuid: status.guid,
            connectionState: state
        };

        if (box?.options?.requiresPlacementGroupToComplete && !hasPlacementGroup) {
            connectionRequestUpdateBag.value.canCompleteRequest = false;
        }
        else if (hasRequiredGroupRequirements) {
            fetchGroupRequirementDetailsForFlyout();
        }
        else {
            connectionRequestUpdateBag.value.canCompleteRequest = true;
        }

        isNoteRequired.value = status.isNoteRequiredOnCompletion;
        anchorEl.value = event.currentTarget as HTMLElement;
        isFlyoutOpen.value = true;
    }

    function onStatusClickFromDockedPanel(event: MouseEvent, canCompleteRequest: boolean): void {
        if (isFlyoutOpen.value) {
            isFlyoutOpen.value = false;
            return;
        }

        connectionRequestUpdateBag.value = {
            connectionRequestIdKey: dockedPanelDetailsBox.value?.entity?.connectionRequestIdKey,
            connectionStatusGuid: dockedPanelDetailsBox.value?.entity?.connectionStatus?.guid,
            connectionState: dockedPanelDetailsBox.value?.entity?.connectionState,
            canCompleteRequest
        };

        isNoteRequired.value = dockedPanelDetailsBox.value?.entity?.connectionStatus?.isNoteRequiredOnCompletion ?? false;
        anchorEl.value = event.currentTarget as HTMLElement;
        isFlyoutOpen.value = true;
    }

    async function fetchGroupRequirementDetailsForFlyout(): Promise<void> {
        isFlyoutCompletionButtonLoading.value = true;

        connectionRequestUpdateBag.value.canCompleteRequest = await checkIfRequestMeetsRequirements(connectionRequestUpdateBag.value.connectionRequestIdKey ?? "");

        isFlyoutCompletionButtonLoading.value = false;
    }

    function onFlyoutClose(): void {
        connectionRequestUpdateBag.value = {} as ConnectionRequestUpdateBag;
        isNoteRequired.value = false;
        anchorEl.value = null;
    }

    function syncGridData(gridRow: Record<string, unknown>): void {
        if (!gridRow) {
            return;
        }

        if (!gridData.value) {
            gridData.value = { rows: [gridRow] };
            return;
        }

        if (!gridData.value.rows) {
            gridData.value.rows = [gridRow];
            return;
        }

        const index = gridData.value.rows.findIndex(r => r.idKey === gridRow.idKey);

        if (index !== -1) {
            gridData.value.rows[index] = gridRow;
        }
        else {
            gridData.value.rows.push(gridRow);
        }
    }

    async function showSMSModal(fromDockedPanel: boolean = false): Promise<void> {
        let selectedKeys: string[];
        let connectionTypeIdKey: string | null | undefined;
        if (fromDockedPanel) {
            selectedKeys = [dockedPanelDetailsBox.value?.entity?.connectionRequestIdKey ?? ""];
            connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;
        }
        else {
            selectedKeys = allSelectedKeys.value;
            connectionTypeIdKey = box.options?.connectionTypeIdKey;
        }

        const result = await getSmsConfiguration(selectedKeys, connectionTypeIdKey);

        if (result.isSuccess && result.data?.communicationRecipients?.length) {
            communicationRecipients.value = result.data.communicationRecipients;
            smsFromSystemPhoneNumbers.value = result.data.smsFromSystemPhoneNumbers ?? [];
            smsSnippets.value = result.data.smsSnippets ?? [];
            isSendSMSModalVisible.value = true;
        }
        else {
            console.error(result.errorMessage);
            // TODO - Show error message to user
            communicationRecipients.value = null;
            smsFromSystemPhoneNumbers.value = [];
            smsSnippets.value = [];
            isSendSMSModalVisible.value = false;
        }
    }

    async function showEmailModal(fromDockedPanel: boolean = false): Promise<void> {
        let selectedKeys: string[];
        let connectionTypeIdKey: string | null | undefined;
        if (fromDockedPanel) {
            selectedKeys = [dockedPanelDetailsBox.value?.entity?.connectionRequestIdKey ?? ""];
            connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;
        }
        else {
            selectedKeys = allSelectedKeys.value;
            connectionTypeIdKey = box.options?.connectionTypeIdKey;
        }

        const result = await getEmailConfiguration(selectedKeys, connectionTypeIdKey);

        if (result.isSuccess && result.data?.communicationRecipients?.length) {
            communicationRecipients.value = result.data.communicationRecipients;
            communicationTemplates.value = result.data.communicationTemplates ?? [];
            isSendEmailModalVisible.value = true;
        }
        else {
            console.error(result.errorMessage);
            // TODO - Show error message to user
            communicationRecipients.value = null;
            communicationTemplates.value = [];
            isSendEmailModalVisible.value = true;
        }
    }

    function clearAllSelections(): void {
        groupedGridPanel.value.clearSelectedKeys();
        // gridRefs.value.forEach(grid => {
        //     console.log("clearning for grid: ", grid);
        //     grid.clearSelectedKeys();
        // });
    }

    async function getSmsConfiguration(selectedKeys: string[], connectionTypeIdKey: string | null | undefined): Promise<HttpResult<GetSmsConfigurationResponseBag>> {
        const bag: GetSmsConfigurationRequestBag = {
            connectionRequestIdKeys: selectedKeys,
            connectionTypeIdKey: connectionTypeIdKey
        };

        const result = await invokeBlockAction<GetSmsConfigurationResponseBag>("GetSmsConfiguration", {
            bag
        });

        return result;
    }

    async function getEmailConfiguration(selectedKeys: string[], connectionTypeIdKey: string | null | undefined): Promise<HttpResult<GetEmailConfigurationResponseBag>> {
        const bag: GetEmailConfigurationRequestBag = {
            connectionRequestIdKeys: selectedKeys,
            connectionTypeIdKey: connectionTypeIdKey
        };

        const result = await invokeBlockAction<GetEmailConfigurationResponseBag>("GetEmailConfiguration", {
            bag
        });

        return result;
    }

    async function updateRequestStatuses(statusUpdateBags: ConnectionRequestUpdateBag[], completedRequestIdKeys: string[]): Promise<void> {
        const result = await invokeBlockAction<ConnectionListGridUpdateBag[]>("UpdateRequestStatuses", {
            statusUpdateBags: statusUpdateBags,
            completedRequestIdKeys: completedRequestIdKeys,
        });

        if (result.isSuccess && result.data) {
            const rowsByIdKey = new Map(
                gridData.value?.rows?.map(r => [r.idKey, r])
            );

            for (const updateBag of result.data) {
                const row = rowsByIdKey.get(updateBag.idKey);
                if (!row) {
                    continue;
                }

                row.stateGrouping = updateBag.stateGrouping;
                row.statusGrouping = updateBag.statusGrouping;
                row.connectionStatus = updateBag.connectionStatusBag;
                row.connectionState = updateBag.connectionState;
                row.dueStatusGrouping = updateBag.dueStatusGrouping;
                row.dueStatus = updateBag.dueStatus;
                row.dueDate = updateBag.dueDate;
                row.dueSoonDate = updateBag.dueSoonDate;
            }

            // clear selected keys
            clearAllSelections();

            isChangeStatusModalVisible.value = false;
            return;
        }

        console.error(result.errorMessage);
    }

    async function changeRequestStatus(bag: ConnectionRequestUpdateBag): Promise<void> {
        try {
            isFlyoutSaving.value = true;

            // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
            const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

            const result = await invokeBlockAction<ConnectionListGridUpdateBag>("ChangeRequestStatus", {
                bag,
                connectionTypeIdKey
            });

            if (result.isSuccess && result.data) {
                const row = gridData.value?.rows?.find(r => r.idKey === bag.connectionRequestIdKey);
                if (row) {
                    row.statusGrouping = result.data.statusGrouping;
                    row.connectionStatus = result.data.connectionStatusBag;
                    row.dueStatusGrouping = result.data.dueStatusGrouping;
                    row.dueStatus = result.data.dueStatus;
                    row.dueDate = result.data.dueDate;
                    row.dueSoonDate = result.data.dueSoonDate;
                }

                if (!!dockedPanelDetailsBox.value?.entity && dockedPanelDetailsBox.value.entity.connectionRequestIdKey === bag.connectionRequestIdKey) {
                    dockedPanelDetailsBox.value.entity.connectionStatus = result.data.connectionStatusBag;
                    dockedPanelDetailsBox.value.entity.dueStatus = result.data.dueStatus;
                    dockedPanelDetailsBox.value.entity.dueDate = result.data.dueDate;
                    refreshActivityEntries(dockedPanelDetailsBox.value.entity.connectionRequestIdKey);
                }

                isFlyoutOpen.value = false;
            }
            // display error
        }
        finally {
            isFlyoutSaving.value = false;
        }
    }

    async function checkIfRequestsMeetRequirements(): Promise<void> {
        areRequestDetailsForModalLoading.value = true;
        const connectionRequestIdKeys = requestDetailsForModal.value.map(r => r.idKey ?? "");

        const result = await invokeBlockAction<string[]>("CheckIfRequestsMeetRequirements", {
            connectionRequestIdKeys
        });

        if (result.isSuccess && result.data) {
            const notMeetingIdKeys = result.data;

            const isPlacementGroupRequired = box.options?.requiresPlacementGroupToComplete;

            const { meeting, notMeeting } = requestDetailsForModal.value.reduce(
                (acc, request) => {
                    if (isPlacementGroupRequired && !request.hasPlacementGroup) {
                        acc.notMeeting.push(request);
                    }

                    if (notMeetingIdKeys.includes(request.idKey ?? "")) {
                        acc.notMeeting.push(request);
                    }
                    else {
                        acc.meeting.push(request);
                    }
                    return acc;
                },
                { meeting: [], notMeeting: [] } as { meeting: BulkRequestViewBag[], notMeeting: BulkRequestViewBag[] });

            requestDetailsForModal.value = meeting;
            failingRequestDetailsForModal.value = notMeeting;
        }
        else {
            console.error("An error occurred while checking group requirements for requests");
        }

        areRequestDetailsForModalLoading.value = false;
    }

    async function checkIfRequestMeetsRequirements(connectionRequestIdKey: string): Promise<boolean> {
        const result = await invokeBlockAction<boolean>("CheckIfRequestMeetsRequirements", {
            connectionRequestIdKey
        });

        if (result.isSuccess) {
            return result.data ?? false;
        }
        else {
            console.error("An error occurred while checking group requirements for requests");
        }

        return false;
    }

    async function updateRequestStates(bag: UpdateConnectionRequestStatesBag): Promise<string | null> {
        // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
        const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

        const result = await invokeBlockAction<ConnectionListGridUpdateBag[]>("UpdateRequestStates", {
            bag: bag,
            connectionTypeIdKey
        });

        if (result.isSuccess && result.data) {
            if (result.data.length === 1) {
                const resultBag = result.data[0];

                const row = gridData.value?.rows?.find(r => r.idKey === resultBag.idKey);

                if (row) {
                    row.stateGrouping = resultBag.stateGrouping;
                    row.connectionState = resultBag.connectionState;
                    row.followUpDate = resultBag.followUpDate;
                }

                // TODO - Determine if we need to make this work for bulk updates. The only case that this would matter is if the selected request
                // was included in the bulk update and then after the bulk update concludes, the user attempts to select the request again.
                if (!!dockedPanelDetailsBox.value?.entity && dockedPanelDetailsBox.value.entity.connectionRequestIdKey === resultBag.idKey) {
                    dockedPanelDetailsBox.value.entity.connectionState = resultBag.connectionState;
                    dockedPanelDetailsBox.value.entity.followUpDate = resultBag.followUpDate;
                    refreshActivityEntries(dockedPanelDetailsBox.value.entity.connectionRequestIdKey);
                }
            }
            else {
                const rowsByIdKey = new Map(
                    gridData.value?.rows?.map(r => [r.idKey, r])
                );

                for (const updateBag of result.data) {
                    const row = rowsByIdKey.get(updateBag.idKey);
                    if (!row) {
                        continue;
                    }

                    row.stateGrouping = updateBag.stateGrouping;
                    row.connectionState = updateBag.connectionState;
                    row.followUpDate = updateBag.followUpDate;
                }
            }

            return null;
        }

        console.error(result.errorMessage);
        return result.errorMessage ?? "An error occurred while updating the connection request state.";
    }

    async function launchWorkflowForRequests(bag: LaunchWorkflowBag): Promise<void> {
        try {
            isModalSaving.value = true;

            // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
            const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

            const result = await invokeBlockAction<LaunchWorkflowResultBag>("LaunchWorkflowForRequests", {
                bag: bag,
                connectionTypeIdKey
            });

            if (result.isSuccess && result.data) {
                isModalAlertVisible.value = true;
                modalAlertText.value = result.data.statusMessage;

                if (!isNullOrWhiteSpace(result.data.workflowEntryPageUrl) && typeof result.data.workflowEntryPageUrl === "string") {
                    const url = result.data.workflowEntryPageUrl;
                    const stop = watch(isModalAlertVisible, (isVisible) => {
                        if (!isVisible) {
                            window.open(url, "_blank");
                            stop(); // tear down watcher
                        }
                    });
                }

                isLaunchWorkflowModalVisible.value = false;

                return;
            }

            console.error(result.errorMessage);
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function deleteRequests(connectionRequestIdKeys: string[]): Promise<boolean> {
        // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
        const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

        const result = await invokeBlockAction("DeleteRequests", {
            connectionRequestIdKeys: connectionRequestIdKeys,
            connectionTypeIdKey
        });

        if (result.isSuccess) {
            const idKeySet = new Set(connectionRequestIdKeys);

            gridData.value!.rows = gridData.value?.rows?.filter(r => !idKeySet.has(r.idKey as string));

            // TODO - Find a better aproach to clearing the selected request
            if (isDockedPanelVisible.value && connectionRequestIdKeys.length === 1 && dockedPanelDetailsBox.value?.entity?.connectionRequestIdKey === connectionRequestIdKeys[0]) {
                selectedRequestKey.value = null;
                isDockedPanelVisible.value = false;
                dockedPanelDetailsBox.value = undefined;
            }

            return true;
        }
        return false;
    }

    function onEditActivity(entry: ActivityEntryBag): void {
        prepareRequestDetailsForModal(null, dockedPanelDetailsBox.value);
        activityToEdit.value = entry;
        isActivityModalVisible.value = true;
    }

    async function upsertActivity(bag: ActivityBag): Promise<void> {
        try {
            isModalSaving.value = true;

            // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
            const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

            // If we have an activity Id Key then we are in update mode.
            if (bag.activityIdKey) {
                await updateActivity(bag, connectionTypeIdKey);
                return;
            }

            const result = await invokeBlockAction<ConnectionListGridUpdateBag[]>("AddActivityForRequests", {
                bag: bag,
                connectionTypeIdKey
            });

            if (result.isSuccess && result.data) {
                if (result.data.length === 1) {
                    const resultBag = result.data[0];

                    const row = gridData.value?.rows?.find(r => r.idKey === resultBag.idKey);

                    if (row) {
                        row.activityCount = resultBag.activityCount;
                        row.lastActivityDateTime = resultBag.lastActivityDateTime;
                    }

                    if (!!dockedPanelDetailsBox.value?.entity && dockedPanelDetailsBox.value.entity.connectionRequestIdKey === resultBag.idKey) {
                        refreshActivityEntries(dockedPanelDetailsBox.value.entity.connectionRequestIdKey);
                    }
                }
                else {
                    const rowsByIdKey = new Map(
                        gridData.value?.rows?.map(r => [r.idKey, r])
                    );

                    for (const updateBag of result.data) {
                        const row = rowsByIdKey.get(updateBag.idKey);
                        if (!row) {
                            continue;
                        }

                        row.activityCount = updateBag.activityCount;
                        row.lastActivityDateTime = updateBag.lastActivityDateTime;
                    }
                }

                isActivityModalVisible.value = false;
                // activityToEdit.value = null;
                return;
            }

            console.error(result.errorMessage);
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function updateActivity(bag: ActivityBag, connectionTypeIdKey: string | null | undefined): Promise<void> {
        const result = await invokeBlockAction<ActivityEntryBag>("UpdateActivity", {
            bag,
            connectionTypeIdKey
        });

        if (result.isSuccess && result.data) {
            if (dockedPanelDetailsBox.value?.entity?.activityEntries) {
                const index = dockedPanelDetailsBox.value.entity.activityEntries.findIndex(a => a.key === result.data?.key);

                if (index !== -1) {
                    dockedPanelDetailsBox.value.entity.activityEntries[index] = result.data;
                }
            }
            isActivityModalVisible.value = false;
            activityToEdit.value = null;
            return;
        }

        console.error(result.errorMessage);
    }

    async function fetchConnectionOpportunityDetails(connectionOpportunityGuid: string): Promise<void> {
        const result = await invokeBlockAction<ConnectionOpportunityDetailBag>("FetchConnectionOpportunityDetails", {
            connectionOpportunityGuid: connectionOpportunityGuid
        });

        if (result.isSuccess && result.data) {
            connectionOpportunityDetails.value = result.data;
        }
        else {
            connectionOpportunityDetails.value = {};
        }
    }

    async function fetchPlacementGroupDetails(connectionOpportunityGuid: string, placementGroupGuid: string): Promise<void> {
        const result = await invokeBlockAction<PlacementGroupDetailsBag>("FetchPlacementGroupDetails", {
            connectionOpportunityGuid: connectionOpportunityGuid,
            placementGroupGuid: placementGroupGuid
        });

        if (result.isSuccess && result.data) {
            placementGroupDetails.value = result.data;
        }
    }

    async function onEditRequest(box: ValidPropertiesBox<ConnectionRequestBag>): Promise<void> {
        try {
            isDockedPanelSaving.value = true;
            const result = await saveConnectionRequest(box);

            if (result.isSuccess && result.data && result.data.detailBox) {
                if (result.data.gridRow) {
                    syncGridData(result.data.gridRow);
                }

                dockedPanelDetailsBox.value = result.data.detailBox;

                connectionRequestDockedPanelRef.value?.setEditMode(false);
            }
            else {
                console.error(result.errorMessage ?? "An unknown error occurred while editing the request.");
            }
        }
        finally {
            isDockedPanelSaving.value = false;
        }
    }

    async function onTransferClick(): Promise<void> {
        const result = await invokeBlockAction<TransferConnectionRequestDetailsBag>("GetTransferDetails", {
            key: dockedPanelDetailsBox.value?.entity?.connectionRequestIdKey
        });

        if (result.isSuccess && result.data) {
            transferRequestDetails.value = result.data;
            isTransferModalVisible.value = true;
        }
        else {
            console.error(result.errorMessage);
        }
    }

    async function transferRequest(bag: TransferConnectionRequestBag): Promise<void> {
        try {
            isModalSaving.value = true;

            const result = await invokeBlockAction<ConnectionListUpdateBox>("TransferConnectionRequest", {
                bag
            });

            if (result.isSuccess && result.data && result.data.detailBox) {
                if (result.data.gridRow) {
                    syncGridData(result.data.gridRow);
                }

                dockedPanelDetailsBox.value = result.data.detailBox;

                isTransferModalVisible.value = false;
            }
            else {
                transferErrorMessage.value = result.errorMessage ?? "An unknown error occurred while transferring the connection request.";
            }
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function checkForActiveRequester(requesterPersonAliasGuid: string): Promise<void> {
        const result = await invokeBlockAction<boolean>("CheckForActiveRequest", {
            requesterPersonAliasGuid,
        });

        if (result.isSuccess && result.data !== null) {
            isExistingActiveRequesterOnConnectionType.value = result.data;
        }
        else {
            console.error(result.errorMessage ?? "An error occurred while checking if the selected requester had any active requests.");
        }
    }

    async function onAddRequest(box: ValidPropertiesBox<ConnectionRequestBag>): Promise<void> {
        try {
            isModalSaving.value = true;

            const result = await saveConnectionRequest(box);

            if (result.isSuccess && result.data) {
                if (result.data.gridRow) {
                    syncGridData(result.data.gridRow);
                }

                isAddConnectionRequestModalVisible.value = false;
                return;
            }
            else {
                console.error(result.errorMessage ?? "An unknown error occurred while adding the request.");
            }
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function saveConnectionRequest(box: ValidPropertiesBox<ConnectionRequestBag>): Promise<HttpResult<ConnectionListUpdateBox>> {
        const result = await invokeBlockAction<ConnectionListUpdateBox>("SaveConnectionRequest", {
            box
        });

        return result;
    }

    async function updateConnectorFromModal(connector: string): Promise<void> {
        try {
            isModalSaving.value = true;
            await reassignConnector(allSelectedKeys.value, connector);
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function reassignConnector(connectionRequestIdKeys: string[], connector: string, fromDockedPanel: boolean = false): Promise<void> {
        // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
        const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

        const result = await invokeBlockAction<ConnectionListGridUpdateBag[]>("ReassignConnector", {
            connectionRequestIdKeys: connectionRequestIdKeys,
            connectorPersonAliasGuid: connector,
            connectionTypeIdKey
        });

        if (result.isSuccess && result.data) {
            const rowsByIdKey = new Map(
                gridData.value?.rows?.map(r => [r.idKey, r])
            );

            for (const updateBag of result.data) {
                const row = rowsByIdKey.get(updateBag.idKey);
                if (!row) {
                    continue;
                }

                row.connectorGrouping = updateBag.connectorGrouping;
                row.connectorDetails = updateBag.connectorDetails;
            }

            if (fromDockedPanel) {
                dockedPanelDetailsBox.value?.entity?.connectorPerson === result.data[0].connectorDetails?.value;
                refreshActivityEntries(connectionRequestIdKeys[0]);
            }
            else {
                // clear selected keys
                clearAllSelections();
            }

            isAssignRequestModalVisible.value = false;
            return;
        }

        console.error(result.errorMessage);
    }

    async function fetchConnectionCampaigns(): Promise<void> {
        const result = await invokeBlockAction<Record<string, ConnectionCampaignBag[]>>("FetchConnectionCampaigns");

        if (result.isSuccess && result.data) {
            campaignRecordBags.value = result.data;
            return;
        }
        console.error(result.errorMessage);
    }

    async function assignRequestsFromCampaign(bag: AssignFromCampaignBag): Promise<void> {
        try {
            isModalSaving.value = true;

            const result = await invokeBlockAction("AssignConnectionRequestsFromCampaign", { bag });

            if (result.isSuccess) {
                // TODO - this may be updated to insert updated/inserted values into the exisithing grid data rather than reloading.
                loadGridData();
                isAddFromCampaignModalVisible.value = false;
                return;
            }

            console.error(result.errorMessage);
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function upsertCelebration(bag: UpsertCelebrationBag): Promise<void> {
        try {
            isModalSaving.value = true;

            // If the action comes from a docked panel than the Connection Type could be different than the Connection Type of the List View.
            const connectionTypeIdKey = dockedPanelDetailsBox.value?.options?.connectionTypeIdKey;

            const result = await invokeBlockAction<ConnectionListGridUpdateBag>("UpsertCelebrationText", { bag, connectionTypeIdKey });

            if (result.isSuccess && result.data) {
                const row = gridData.value?.rows?.find(r => r.idKey === result.data?.idKey);

                if (row) {
                    row.celebrationText = result.data.celebrationText;
                }
                if (dockedPanelDetailsBox.value?.entity) {
                    dockedPanelDetailsBox.value.entity.celebrationText = result.data.celebrationText;
                }

                isCelebrationModalVisible.value = false;
                return;
            }

            console.error(result.errorMessage);
        }
        finally {
            isModalSaving.value = false;
        }
    }

    async function getConnectionRequestDetails(requestIdKey: string): Promise<void> {
        dockedPanelDetailsBox.value = undefined;

        const result = await invokeBlockAction<ConnectionRequestDetailBox>("GetConnectionRequestDetails", { connectionRequestIdKey: requestIdKey });

        if (result.isSuccess && result.data) {
            dockedPanelDetailsBox.value = result.data;
            return;
        }

        console.error(result.errorMessage);
    }

    async function refreshActivityEntries(requestIdKey: string | null | undefined): Promise<void> {
        // We only need to refresh activity entries if the docked panel is open and has data.
        if (!isDockedPanelVisible.value || !dockedPanelDetailsBox.value?.entity || !requestIdKey) {
            return;
        }

        const result = await invokeBlockAction<ActivityEntryBag[]>("GetActivityEntries", {
            connectionRequestIdKey: requestIdKey
        });

        if (result.isSuccess && result.data) {
            dockedPanelDetailsBox.value.entity.activityEntries = result.data;
        }
        else {
            console.error(result.errorMessage);
        }
    }

    // When any modal is open, disable close-on-outside-click for the docked panel so that
    // clicking inside a modal doesn't accidentally close the panel behind it.
    watch([isTransferModalVisible, isCelebrationModalVisible, isActivityModalVisible, isReminderModalVisible, isSendSMSModalVisible, isSendEmailModalVisible, isFlyoutOpen, isModalAlertVisible, isDeleteRequestModalVisible], (values) => {
        handleClickOutsideSettingForDockedPanel(!values.some(Boolean));
    });

    watch(areOnlyMyRequestsVisible, async () => {
        // This prevents saving a "Selected Connector" as this person prefernce
        if (areOnlyMyRequestsVisible.value !== "true" && areOnlyMyRequestsVisible.value !== "false") {
            return;
        }

        preferences.setValue(PreferenceKey.AreOnlyMyRequestsVisible, areOnlyMyRequestsVisible.value);

        const connectorIndex = requestToggleItems.value.findIndex(i => i.value !== "true" && i.value !== "false");
        if (connectorIndex !== -1) {
            // Clears the selected connector person preference, removes their item from the dropdown, and clears the query param.
            preferences.setValue(PreferenceKey.SelectedConnector, "");
            requestToggleItems.value.splice(connectorIndex, 1);
            removeCurrentUrlQueryParams("Connector");
        }

        await preferences.save();

        loadGridData();
    });

    watch(selectedOpportunity, async () => {
        preferences.setValue(getConnectionFilterKey(PreferenceKey.ConnectionmOpportunityFilterConnectionTypeIdKey), selectedOpportunity.value);

        await preferences.save();

        newConnectionRequest.value.bag = {
            connectionOpportunityGuid: selectedOpportunity.value
        };
        if (!isNullOrWhiteSpace(selectedOpportunity.value)) {
            await fetchConnectionOpportunityDetails(selectedOpportunity.value);
        }
        else {
            connectionOpportunityDetails.value = {};
        }

        // Remove the Connection Opportunity query param and ensure ConnectionType is present.
        removeCurrentUrlQueryParams("ConnectionOpportunity");

        // If there is no connection type query string parameter present, we need to add it
        // because we've just removed the Connection Opportunity query string parameter.
        if (box.options?.connectionTypeIdKey) {
            const url = new URL(window.location.href);
            if (!url.searchParams.has("ConnectionType")) {
                url.searchParams.set("ConnectionType", box.options.connectionTypeIdKey);
                history.replaceState(null, "", url.toString());
            }
        }

        // TODO - client side filter?
        loadGridData();
    });

    // Ensure the selected grouping remains valid when the available grouping options
    // change (e.g., when filtering out opportunity grouping after selecting an opportunity).
    watch(groupingFields, (newFields) => {
        const selected = selectedGrouping.value;

        const isStillValid = newFields.some(f => f.value === selected);

        if (!isStillValid) {
            selectedGrouping.value = newFields[0]?.value ?? "";
        }
    });

    watch(viewOptions, async () => {
        preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterSortByConnectionTypIdKey), viewOptions.value.sortBy ?? "");
        // preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterIsAssignedToMeConnectionTypeIdKey), viewOptions.value.isAssignedToMe.toString());
        preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterGridDataToShowConnectionTypIdKey), JSON.stringify(viewOptions.value.gridDataToShow));
        preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterIsRequestSourceShownConnectionTypIdKey), viewOptions.value.isRequestSourceShown.toString());
        preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterStateConnectionTypIdKey), JSON.stringify(viewOptions.value.stateFilter));
        preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterStatusConnectionTypIdKey), JSON.stringify(viewOptions.value.statusFilter));
        preferences.setValue(getConnectionFilterKey(PreferenceKey.FilterDueConnectionTypIdKey), JSON.stringify(viewOptions.value.dueFilter));

        await preferences.save();
    });

    // watch(newConnectionRequest, () => {
    //     onAddRequest(newConnectionRequest.value);
    // });

    watch(selectedGrouping, async () => {
        preferences.setValue(PreferenceKey.SelectedGroupByMode, selectedGrouping.value);

        await preferences.save();
    });

    watch(selectedRequestKey, async () => {
        if (!isNullOrWhiteSpace(selectedRequestKey.value)) {
            await getConnectionRequestDetails(selectedRequestKey.value);
        }
    });

    watch(isActivityModalVisible, (isVisible) => {
        if (!isVisible) {
            activityToEdit.value = null;
        }
    });

    watch(rawQuickFilter, debounce(() => {
        debouncedQuickFilter.value = rawQuickFilter.value;
    }, 150));

    loadGridData();

    // TODO - Load a single request at full width.
    // if (!isNullOrWhiteSpace(box.options?.connectionRequestIdKey)) {
    //     loadConnectionRequest();
    // }

    onConfigurationValuesChanged(useReloadBlock());
</script>