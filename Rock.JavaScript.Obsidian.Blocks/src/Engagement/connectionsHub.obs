    function onStatusClick(key: string | null | undefined, status: ConnectionStatusBag | null | undefined, state: ConnectionState | null | undefined, event: MouseEvent): void {
        if (!status || !key || state === null || state === undefined || typeof status !== "object" || typeof key !== "string" || typeof state !== "number") {
            return;
        }

        connectionRequestUpdateBag.value = {
            connectionRequestIdKey: key,
            connectionStatusGuid: status.guid,
            connectionState: state
        };
        isNoteRequired.value = status.isNoteRequiredOnCompletion;
        anchorEl.value = event.currentTarget as HTMLElement;
        console.log("made it here: ", connectionRequestUpdateBag.value);
        isFlyoutOpen.value = true;
    }

    function onFlyoutClose(): void {
        connectionRequestUpdateBag.value = {} as ConnectionRequestUpdateBag;
        isNoteRequired.value = false;
        anchorEl.value = null;
    }

