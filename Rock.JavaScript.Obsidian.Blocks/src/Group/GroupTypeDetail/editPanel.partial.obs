<!-- Copyright by the Spark Development Network; Licensed under the Rock Community License -->
<template>
    <ContentSectionContainer sidebar>
        <ContentSection light>
            <div class="basic-fields">
                <NotificationBox v-if="isSystem" :alertType="AlertType.Info">
                    <strong>Note</strong> Because this group type is used by Rock, editing is restricted.
                </NotificationBox>

                <NotificationBox v-if="errorMessage" :alertType="AlertType.Danger">
                    {{ errorMessage }}
                </NotificationBox>

                <div class="row">
                    <div class="col-md-6">
                        <TextBox v-model="name" label="Name" rules="required" :disabled="isSystem" />
                    </div>
                </div>

                <TextBox v-model="description" label="Description" textMode="multiline" :disabled="isSystem" />

                <div class="row">
                    <div class="col-md-3">
                        <ColorPicker v-model="groupTypeColor" label="Group Type Color"
                                     help="Specifies the color used to visually distinguish this group type in lists."
                                     trailblazerField />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <IconPicker v-model="iconCssClass" label="Group Type Icon"
                                    help="Specifies the icon used to represent groups of this type." />
                    </div>
                </div>
            </div>
        </ContentSection>

        <!-- GENERAL -->
        <ContentSection title="General" icon="ti ti-settings" :order="1">
            <ContentStack title="Purpose &amp; Structure"
                          description="Defines the overall purpose, identity, and hierarchical relationships of the group type, including what it inherits and what children it can contain.">
                <DefinedValuePicker label="Group Type Purpose" v-model="groupTypePurposeValue" :showBlankItem="true"
                                    help="Defines the overall purpose of this group type. This field is optional. To add or edit available options, update the 'Group Type Purpose' Defined Type."
                                    :definedTypeGuid="DefinedType.GrouptypePurpose" trailblazerField enhanceForLongLists
                                    :disabled="isSystem" />

                <GroupTypePicker label="Inherit Group Type Attributes From" v-model="inheritedGroupType"
                                 :showBlankItem="true" :excludeGroupTypes="excludedGroupTypes"
                                 help="Select which Group Type to inherit attributes from." trailblazerField enhanceForLongLists
                                 :disabled="isSystem" />

                <div class="form-group">
                    <InlineCheckBox label="Allow Any Child Group Type" v-model="allowAnyChildGroupType"
                                    help="When enabled, groups of any type can be added as child groups to this group type." />
                </div>

                <div v-if="!allowAnyChildGroupType" class="allow-any-child-groupType">
                    <GroupTypePicker label="Allowed Child Group Types" v-model="childGroupTypes" multiple
                                     :showBlankItem="true" enhanceForLongLists
                                     help="Defines which child group types can be added to groups of this type. This setting controls the group hierarchy. To allow an unlimited hierarchy, include this group type as one of its own allowed child types." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Require Campus For Groups" v-model="groupsRequireCampus"
                                    help="When enabled, all groups of this type must have a campus selected when being added or edited." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Enable Group Administrator" v-model="showAdministrator"
                                    help="When enabled, groups of this type can have an assigned group administrator." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Enable Specific Group Requirements" v-model="enableSpecificGroupRequirements"
                                    help="When enabled, groups of this type can have their own Group Requirements. This displays the Group Requirements section on the Group Details block. If a group already has specific requirements, the section will remain visible even when this setting is disabled." />
                </div>
            </ContentStack>

            <ContentStack title="Location &amp; Scheduling"
                          description="Configures how locations are chosen, how many can be used, whether schedules tie to locations, and which location types are allowed.">
                <CheckBoxList label="Allowed Location Selection Modes" v-model="locationSelectionModeValue"
                              :items="locationSelectionModeOptions" :repeatColumns="2"
                              help="Specifies which location selection modes are available when adding locations to groups of this type."
                              :disabled="isSystem" />

                <DefinedValuePicker label="Allowed Location Types" v-model="locationTypes" :multiple="true"
                                    :definedTypeGuid="DefinedType.GroupLocationType"
                                    help="Defines the location types that can be associated with groups of this type. For example, you might include a meeting location and an assignment target location." />

                <div class="form-group">
                    <InlineCheckBox label="Allow Multiple Locations" v-model="allowMultipleLocations"
                                    help="When enabled, groups of this type can have more than one location."
                                    :disabled="isSystem" />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Enable Location Schedules" v-model="enableLocationSchedules"
                                    help="When enabled, group locations can be linked to one or more predefined schedules."
                                    :disabled="isSystem" />
                </div>
            </ContentStack>

            <ContentStack title="Capacity &amp; Status" description="Controls how group capacity is enforced.">
                <div class="row">
                    <div class="col-md-6">
                        <RadioButtonList label="Group Capacity Enforcement" v-model="groupCapacityRuleValue"
                                         :items="enumToListItemBag(GroupCapacityRuleDescription)"
                                         help="Specifies whether this group type supports a capacity limit and how that limit is enforced." />
                    </div>
                    <div class="col-md-6">
                        <CheckBox v-if="groupCapacityRule !== GroupCapacityRule.None" label="Require Group Capacity"
                                  v-model="isCapacityRequired"
                                  help="When enabled, a Group Capacity value is required for all groups of this type." />
                    </div>
                </div>

                <DropDownList label="Group Status Defined Type" v-model="groupStatusDefinedTypeValue"
                              :items="props.options.definedTypeOptions ?? []" :showBlankItem="true" enhanceForLongLists
                              help="Specifies the Defined Type used to set a group's status. Leave blank if groups of this type should not prompt for a status."
                              trailblazerField :disabled="isSystem" />

            </ContentStack>

            <ContentStack title="Record Source &amp; Group-Specific Settings"
                          description="Determines what record source to add to members of this group type and which group-specific settings to allow.">
                <DefinedValuePicker label="Group Member Record Source" v-model="groupMemberRecordSourceValue"
                                    :definedTypeGuid="DefinedType.RecordSourceType" :showBlankItem="true" enhanceForLongLists
                                    help="Specifies the record source to assign to group members added to groups of this type." />

                <div class="form-group">
                    <div class="allowed-group-specific-settings">
                        <RockLabel>Allowed Group Specific Settings</RockLabel>
                    </div>
                    <InlineCheckBox label="Record Source" v-model="allowGroupSpecificRecordSource"
                                    help="When enabled, groups of this type can override the default record source." />

                    <InlineCheckBox label="Member Attributes" v-model="allowSpecificGroupMemberAttributes"
                                    help="When enabled, groups of this type can have their own Group Member Attributes. This displays the Member Attributes section on the Group Details block. Existing specific member attributes are preserved." />

                    <InlineCheckBox label="Member Workflows" v-model="allowSpecificGroupMemberWorkflows"
                                    help="When enabled, groups of this type can have their own Group Member Workflows. This displays the Group Member Workflows section on the Group Details block. Existing workflows are retained even if this setting is later disabled." />

                    <InlineCheckBox label="Tags" v-model="enableGroupTag"
                                    help="When enabled, groups of this type can create and manage their own tags." />
                </div>
            </ContentStack>

            <ContentStack title="System Management"
                          description="Manages system features for syncing and tracking groups.">
                <div class="form-group">
                    <InlineCheckBox label="Preserve Member Status on Person Inactivation"
                                    v-model="ignorePersonInactivated"
                                    help="When enabled, members of groups of this type will remain active even if their person record is inactivated."
                                    trailblazerField />
                </div>

                <div v-if="props.options.isIndexingOptionAvailable" class="form-group">
                    <InlineCheckBox label="Enable Universal Search Indexing" v-model="isIndexEnabled"
                                    help="When enabled, groups of this type are included in Universal Search indexing."
                                    trailblazerField />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Enable Group History Tracking" v-model="enableGroupHistory"
                                    help="When enabled, groups of this type will track changes to the group and its members in Group History." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Allow Group Sync" v-model="allowGroupSync"
                                    help="When enabled, groups of this type can use Group Sync. This displays the Group Sync Settings section on the Group Details block. Existing syncs are retained, and disabling this setting does not stop them from running." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Allow Inactivation Reasons" v-model="enableInactiveReasonValue"
                                    help="When enabled, a reason can be selected when a group is inactivated. The available reasons are defined in the Inactive Group Reasons Defined Type."
                                    trailblazerField />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Require Inactive Reason" v-model="requiresInactiveReason"
                                    help="When enabled, an Inactive Reason must be selected when a group is inactivated. The available reasons are defined in the Inactive Group Reasons Defined Type."
                                    :disabled="!enableInactiveReason" trailblazerField />
                </div>
            </ContentStack>
        </ContentSection>

        <!-- DISPLAY OPTIONS -->
        <ContentSection title="Display Options" icon="ti ti-device-desktop" :order="2">
            <ContentStack title="Group Appearance"
                          description="Customize how groups of this type appear throughout Rock.">
                <TextBox v-model="groupTerm" label="Group Term" rules="required"
                         help="Defines the term used to refer to groups of this type." :disabled="isSystem" />

                <TextBox v-model="groupMemberTerm" label="Group Member Term" rules="required"
                         help="Defines the term used to refer to members within groups of this type." :disabled="isSystem" />

                <TextBox v-if="showAdministrator" v-model="administratorTerm" label="Administrator Term"
                         rules="required" help="Defines the term used for the administrator of groups of this type."
                         :disabled="isSystem" />

                <div class="form-group">
                    <InlineCheckBox label="Show in Group Lists" v-model="showInGroupList"
                                    help="When enabled, groups of this type appear in the GroupList block's list of groups." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Show in Group Navigation" v-model="showInNavigation"
                                    help="When enabled, groups of this type appear in the GroupTreeView block's navigation panel." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Show Connection Status in Group Member List" v-model="showConnectionStatus"
                                    help="When enabled, the connection status of each person is displayed as a column in the group member list." />
                </div>

                <div class="form-group">
                    <InlineCheckBox label="Show Marital Status in Group Member List" v-model="showMaritalStatus"
                                    help="When enabled, the marital status of each person is displayed as a column in the group member list." />
                </div>

            </ContentStack>

            <ContentStack v-if="props.options.enableGroupViewLavaTemplate" title="Group View Lava Template"
                          description="This Lava template will be used by the Group Details block when viewing a group. This allows you to customize the layout of a group base on its type.">
                <HtmlEditor v-model="groupViewLavaTemplate" :editorHeight="400" :startInCodeEditorMode="true" />
            </ContentStack>
        </ContentSection>

        <!-- ROLES -->
        <ContentSection title="Roles" icon="ti ti-masks-theater" :order="3">
            <GroupTypeRoles v-model:roles="roles" v-model:defaultGroupRole="defaultGroupRole"
                            :isChatAllowed="isChatAllowed" :groupRequirementRoles="groupRequirementRoles"
                            :workflowTriggerRoles="workflowTriggerRoles" :groupTerm="groupTerm"
                            :groupMemberTerm="groupMemberTerm" />
        </ContentSection>

        <!-- GROUP TYPE ATTRIBUTES -->
        <ContentSection title="Type Attributes" icon="ti ti-binary-tree-2" :order="4">
            <GroupTypeAttributes v-model:groupTypeAttributes="groupTypeAttributes"
                                 v-model:attributeValues="attributeValues" :inheritedGroupTypeAttributes="inheritedGroupTypeAttributes"
                                 :attributesForAttributeValueContainer="attributes" />
        </ContentSection>

        <!-- GROUP ATTRIBUTES -->
        <ContentSection title="Group Attributes" icon="ti ti-users-group" :order="5">
            <GroupAttributes v-model:groupAttributes="groupAttributes"
                             :inheritedGroupAttributes="inheritedGroupAttributes" />
        </ContentSection>

        <!-- GROUP MEMBER ATTRIBUTES -->
        <ContentSection title="Member Attributes" icon="ti ti-user-cog" :order="6">
            <GroupMemberAttributes v-model:groupMemberAttributes="groupMemberAttributes"
                                   :inheritedGroupMemberAttributes="inheritedGroupMemberAttributes" />
        </ContentSection>

        <!-- SCHEDULING -->
        <ContentSection title="Scheduling" icon="ti ti-calendar-month" :order="7">
            <ContentStack :title="schedulingSectionTitle" :description="schedulingSectionDescription">
                <div class="form-group">
                    <InlineSwitch label="Enable Scheduling" v-model="isSchedulingEnabled" />
                </div>
            </ContentStack>

            <TransitionVerticalCollapse>
                <div v-if="isSchedulingEnabled" class="contentsection-body-collapse">
                    <ContentStack title="Confirmations"
                                  description="Controls how and when group members are notified about their scheduled assignments, including confirmation messages and coordinator notifications.">
                        <DropDownList label="Schedule Confirmation Communication"
                                      v-model="scheduleConfirmationSystemCommunicationGuid"
                                      :items="props.options.systemCommunicationOptions ?? []" :showBlankItem="true"
                                      enhanceForLongLists
                                      help="Specifies the System Communication used when a person is scheduled or when their schedule is updated." />
                        <div class="form-group">
                            <InlineCheckBox label="Require Reason if Schedule Declined"
                                            v-model="requiresReasonIfDeclineSchedule"
                                            help="When enabled, individuals must provide a reason when declining or canceling a scheduled assignment." />
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <NumberBox label="Schedule Confirmation Lead Time"
                                           v-model="scheduleConfirmationEmailOffsetDays" :minimumValue="0"
                                           help="Defines how many days before the scheduled date a confirmation notification is sent.">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">Days</span>
                                    </template>
                                </NumberBox>
                            </div>
                        </div>
                        <RadioButtonList label="Schedule Confirmation Behavior" v-model="scheduleConfirmationLogicValue"
                                         :items="enumToListItemBag(ScheduleConfirmationLogicDescription)"
                                         help="Specifies whether individuals are prompted to accept or decline a schedule or if their assignment is automatically accepted. This setting applies by default to all groups of this type." />
                        <CheckBoxList label="Coordinator Notification Triggers"
                                      v-model="scheduleCoordinatorNotificationTypesValue"
                                      :items="scheduleCoordinatorNotificationTypesOptions"
                                      help="Specifies which notifications coordinators receive about scheduled individuals. For example, selecting “Self-Schedule” notifies the coordinator when someone signs up for additional times via the Group Schedule Toolbox." />
                    </ContentStack>
                    <ContentStack title="Reminders"
                                  description="Set up reminders sent before the event to keep attendees informed.">
                        <DropDownList label="Schedule Reminder Communication"
                                      v-model="scheduleReminderSystemCommunicationGuid"
                                      :items="props.options.systemCommunicationOptions ?? []" :showBlankItem="true"
                                      enhanceForLongLists
                                      help="Specifies the System Communication used to send schedule reminders." />
                        <div class="row">
                            <div class="col-md-6">
                                <NumberBox label="Schedule Reminder Lead Time" v-model="scheduleReminderEmailOffsetDays"
                                           :minimumValue="0"
                                           help="Defines the default number of days before a scheduled event that a reminder notification is sent.">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">Days</span>
                                    </template>
                                </NumberBox>
                            </div>
                        </div>
                    </ContentStack>
                    <ContentStack v-if="store.state.trailblazerMode" title="Cancellation Settings"
                                  description="Manage workflow for when a registration is canceled.">
                        <WorkflowTypePicker label="Schedule Cancellation Workflow"
                                            v-model="scheduleCancellationWorkflowType" :showBlankItem="true"
                                            help="Specifies the workflow type that runs when a person indicates they cannot attend their scheduled time." />
                    </ContentStack>
                </div>
            </TransitionVerticalCollapse>
        </ContentSection>

        <!-- PEER NETWORK -->
        <ContentSection title="Peer Network" icon="ti ti-affiliate" :order="8">
            <ContentStack title="Peer Network Feature" :description="peerNetworkSectionDescription">
                <div class="form-group">
                    <InlineSwitch label="Enable Peer Network" v-model="isPeerNetworkEnabled" />
                </div>
            </ContentStack>

            <TransitionVerticalCollapse>
                <div v-if="isPeerNetworkEnabled" class="contentsection-body-collapse">
                    <ContentStack title="Relationship Settings"
                                  description="Manage how connected group members are and if their relationships can develop over time.">
                        <RadioButtonList label="Group Relationship Strength" v-model="relationshipStrengthValue"
                                         :items="enumToListItemBag(RelationshipStrengthDescription)"
                                         help="Specifies the relationship strength between individuals in groups of this type. Advanced settings allow further customization based on each person’s group role." />
                        <div class="form-group">
                            <InlineCheckBox label="Enable Relationship Growth Over Time"
                                            v-model="relationshipGrowthEnabled"
                                            help="When enabled, relationship strength can increase over time as individuals spend more time together in the group." />
                        </div>
                    </ContentStack>
                    <ContentStack v-if="store.state.trailblazerMode" title="Relationship Scoring"
                                  description="Use the matrix to adjust relationship scores based on group member relationships. For example, if members have strong connections with group leaders but little interaction with other non-leaders, you can reduce or remove the score percentage between non-leaders.">
                        <div class="d-grid grid-cols-3 gap-2" style="width: max-content;">
                            <!-- Header Row -->
                            <div></div>
                            <div class="d-flex align-items-center">
                                <RockLabel>Leader</RockLabel>
                            </div>
                            <div class="d-flex align-items-center">
                                <RockLabel>Non-Leader</RockLabel>
                            </div>
                            <!-- Leader Row -->
                            <div class="d-flex align-items-center">
                                <RockLabel>Leader</RockLabel>
                            </div>
                            <div class="d-flex align-items-center">
                                <NumberBox v-model="leaderToLeaderRelationshipMultiplierValue" :decimalCount="0"
                                           :minimumValue="0" :maximumValue="100" :maxLength="3" style="width: 100px;"
                                           validationTitle="Leader to Leader Relationship Multiplier">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">%</span>
                                    </template>
                                </NumberBox>
                            </div>
                            <div class="d-flex align-items-center">
                                <NumberBox v-model="leaderToNonLeaderRelationshipMultiplierValue" :decimalCount="0"
                                           :minimumValue="0" :maximumValue="100" :maxLength="3" style="width: 100px;"
                                           validationTitle="Leader to Non-Leader Relationship Multiplier">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">%</span>
                                    </template>
                                </NumberBox>
                            </div>
                            <!-- Non-Leader Row -->
                            <div class="d-flex align-items-center">
                                <RockLabel>Non-Leader</RockLabel>
                            </div>
                            <div class="d-flex align-items-center">
                                <NumberBox v-model="nonLeaderToLeaderRelationshipMultiplierValue" :decimalCount="0"
                                           :minimumValue="0" :maximumValue="100" :maxLength="3" style="width: 100px;"
                                           validationTitle="Non-Leader to Leader Relationship Multiplier">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">%</span>
                                    </template>
                                </NumberBox>
                            </div>
                            <div class="d-flex align-items-center">
                                <NumberBox v-model="nonLeaderToNonLeaderRelationshipMultiplierValue" :decimalCount="0"
                                           :minimumValue="0" :maximumValue="100" :maxLength="3" style="width: 100px;"
                                           validationTitle="Non-Leader to Non-Leader Relationship Multiplier">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">%</span>
                                    </template>
                                </NumberBox>
                            </div>
                        </div>
                    </ContentStack>
                </div>
            </TransitionVerticalCollapse>
        </ContentSection>

        <!-- ATTENDANCE -->
        <ContentSection title="Attendance" icon="ti ti-clipboard-check" :order="9">
            <ContentStack title="Attendance &amp; Check-In Features"
                          description="Enable groups of this type to take and manage attendance.">
                <div class="form-group">
                    <InlineSwitch label="Enable Attendance Tracking" v-model="takesAttendance" />
                </div>
            </ContentStack>

            <TransitionVerticalCollapse>
                <div v-if="takesAttendance" class="contentsection-body-collapse">
                    <ContentStack title="Attendance Settings"
                                  description="Define how attendance is tracked for this group, including schedule options, exclusions, and location or schedule requirements.">

                        <CheckBoxList label="Available Group Schedule Types" v-model="allowedScheduleTypesValue"
                                      :items="allowedScheduleTypesOptions"
                                      help="Specifies which schedule option types are available when editing groups of this type."
                                      :disabled="isSystem" />

                        <NotificationBox v-if="scheduleExclusionsErrorMessage" :alertType="AlertType.Danger">
                            {{ scheduleExclusionsErrorMessage }}
                        </NotificationBox>
                        <div class="form-group">
                            <RockLabel help="Defines the date ranges when groups of this type do not meet, regardless of their individual schedules.">
                                Schedule Exclusions
                            </RockLabel>
                            <Grid :data="groupScheduleExclusionsGridData" keyField="guid" itemTerm="Schedule Exclusion"
                                  liveUpdates light @addItem="onAddScheduleExclusion">
                                <TextColumn name="dateRange" field="dateRange" />
                                <EditColumn @click="onEditScheduleExclusion" />
                                <DeleteColumn @click="onDeleteScheduleExclusion" disableConfirmation />
                            </Grid>
                        </div>

                        <div class="form-group">
                            <InlineCheckBox label="Count Attendance Toward Weekend Service"
                                            v-model="attendanceCountsAsWeekendService"
                                            help="When enabled, attendance in groups of this type is counted toward weekend service attendance." />
                        </div>
                        <div class="form-group">
                            <InlineCheckBox label="Location Required for Attendance"
                                            v-model="groupAttendanceRequiresLocation"
                                            help="When enabled, all attendance occurrences for groups of this type must include a location."
                                            trailblazerField />
                        </div>
                        <div class="form-group">
                            <InlineCheckBox label="Schedule Required for Attendance"
                                            v-model="groupAttendanceRequiresSchedule"
                                            help="When enabled, all attendance occurrences for groups of this type must include a schedule."
                                            trailblazerField />
                        </div>
                    </ContentStack>
                    <ContentStack title="Attendance Notifications"
                                  description="Set up automatic reminders to encourage attendance or follow-up communication after events.">
                        <div class="form-group">
                            <InlineCheckBox label="Enable Attendance Reminder" v-model="sendAttendanceReminder"
                                            help="When enabled, automatic attendance reminders are sent for all groups of this type." />
                        </div>
                        <ConditionalWell v-if="sendAttendanceReminder">
                            <DropDownList label="Attendance Reminder Communication"
                                          v-model="attendanceReminderSystemCommunicationGuid"
                                          :items="props.options.systemCommunicationOptions ?? []" :showBlankItem="true"
                                          enhanceForLongLists
                                          help="Specifies the communication template used when sending attendance reminders for groups of this type."
                                          rules="required" />

                            <div class="row">
                                <div class="col-md-6">
                                    <NumberBox label="Attendance Reminder Lead Time"
                                               v-model="attendanceReminderSendStartOffsetMinutes" :minimumValue="0"
                                               help="Defines how many minutes before a group starts the attendance reminder is sent, when “Send Attendance Reminder” is enabled. The Send Group Attendance Reminders job runs every 15 minutes and only sends reminders once this time has passed for a group.">
                                        <template #inputGroupAppend>
                                            <span class="input-group-addon">Minutes</span>
                                        </template>
                                    </NumberBox>
                                </div>
                            </div>

                            <CheckBoxList label="Attendance Reminder Follow-Up"
                                          v-model="attendanceReminderFollowupDaysValue"
                                          :items="attendanceReminderFollowupDaysOptions"
                                          help="Specifies which days after an occurrence a reminder should be sent if attendance has not been entered. Follow-up reminders are sent at the same time as the original reminder." />
                        </ConditionalWell>
                    </ContentStack>
                </div>
            </TransitionVerticalCollapse>
            <Modal v-model="isScheduleExclusionModalVisible"
                   :title="`${isEditingScheduleExclusion ? 'Edit' : 'Add'} Schedule Exclusion`" saveText="Save"
                   cancelText="Cancel" :onSave="onSaveScheduleExclusion">
                <div class="row">
                    <div class="col-md-12">
                        <DateRangePicker v-model="editingScheduleExclusionDateRange" label="Schedule Exclusion"
                                         rules="required" />
                    </div>
                </div>
            </Modal>
        </ContentSection>

        <!-- RSVP -->
        <ContentSection title="RSVP" icon="ti ti-ticket" :order="10">
            <ContentStack title="RSVP Feature" description="This option will allow group RSVP.">
                <div class="form-group">
                    <InlineSwitch label="Enable RSVP" v-model="enableRSVP" />
                </div>
            </ContentStack>

            <TransitionVerticalCollapse>
                <div v-if="enableRSVP" class="contentsection-body-collapse">
                    <ContentStack title="Reminder Settings"
                                  description="Configure RSVP reminders and messages sent to members before an event.">
                        <DropDownList label="RSVP Reminder Communication" v-model="rsvpReminderSystemCommunicationGuid"
                                      :items="props.options.rsvpSystemCommunicationOptions ?? []" :showBlankItem="true" enhanceForLongLists
                                      help="Specifies the System Communication used to remind group members to RSVP for upcoming group events."
                                      rules="required" />

                        <div class="row">
                            <div class="col-md-6">
                                <NumberBox label="RSVP Reminder Lead Time" v-model="rsvpReminderOffsetDays"
                                           :minimumValue="0" :maximumValue="30"
                                           help="Defines how many days (between 0 and 30) before a group event the RSVP reminder is sent. Set to 0 to manage the reminder timing at the individual group level."
                                           rules="required">
                                    <template #inputGroupAppend>
                                        <span class="input-group-addon">Days</span>
                                    </template>
                                </NumberBox>
                            </div>
                        </div>

                    </ContentStack>
                </div>
            </TransitionVerticalCollapse>
        </ContentSection>

        <!-- CHAT -->
        <ContentSection v-if="store.state.trailblazerMode && isChatEnabledSystem" title="Chat"
                        icon="ti ti-message-dots"
                        :order="11">
            <NotificationBox :alertType="AlertType.Info">
                You'll need to run the Chat Sync Job after saving for these changes to take effect in chat channels of this type.
            </NotificationBox>

            <NotificationBox v-if="chatChannelsDisabledMessage" :alertType="AlertType.Warning">
                {{ chatChannelsDisabledMessage }}
            </NotificationBox>

            <ContentStack title="Chat Feature"
                          description="Enable groups of this type to participate in the chat system as chat channels.">
                <div class="form-group">
                    <InlineSwitch label="Enable Chat" v-model="isChatAllowed" :disabled="isSystem" />
                </div>
            </ContentStack>

            <TransitionVerticalCollapse>
                <div v-if="isChatAllowed" class="contentsection-body-collapse">
                    <ContentStack title="Group Chat Settings"
                                  description="Control how group chat works for this group type.">
                        <div class="form-group">
                            <InlineCheckBox label="Enable Chat for All Groups" v-model="isChatEnabledForAllGroups"
                                            help="When enabled, all groups of this type have chat functionality enabled by default."
                                            :disabled="isSystem" />
                        </div>

                        <div class="form-group">
                            <InlineCheckBox label="Allow Members to Leave Chat Channel"
                                            v-model="isLeavingChatChannelAllowed"
                                            help="When enabled, individuals can leave chat channels of this group type."
                                            :disabled="isSystem" />
                        </div>

                        <div class="form-group">
                            <InlineCheckBox label="Make Chat Channel Public" v-model="isChatChannelPublic"
                                            help="When enabled, chat channels of this type are public and visible to everyone in search results. Public channels can be joined by anyone through the chat application."
                                            :disabled="isSystem" />
                        </div>

                        <div class="form-group">
                            <InlineCheckBox label="Always Show Chat Channel" v-model="isChatChannelAlwaysShown"
                                            help="When enabled, chat channels of this type are always shown in the channel list, even for people who have not joined. Public visibility also allows anyone to join via the chat application."
                                            :disabled="isSystem" />
                        </div>
                    </ContentStack>

                    <RadioButtonList label="Default Channel Notification Setting"
                                     v-model="chatPushNotificationModeValue"
                                     :items="enumToListItemBag(ChatNotificationModeDescription)"
                                     help="Specifies how push notifications are sent for chat channels of this type."
                                     :disabled="isSystem" />
                </div>
            </TransitionVerticalCollapse>
        </ContentSection>

        <!-- GROUP REQUIREMENTS -->
        <ContentSection v-if="store.state.trailblazerMode" title="Group Requirements" icon="ti ti-checklist" :order="12">
            <GroupRequirements v-model:groupRequirements="groupRequirements"
                               :groupRequirementTypeOptions="groupRequirementTypeOptions" :groupRoleOptions="groupRoleOptions"
                               :groupAttributeOptions="groupAttributeOptions" />
        </ContentSection>

        <!-- GROUP MEMBER WORKFLOWS -->
        <ContentSection v-if="store.state.trailblazerMode" title="Group Member Workflows" icon="ti ti-settings-cog" :order="13">
            <GroupMemberWorkflows v-model:groupMemberWorkflowTriggers="groupMemberWorkflowTriggers"
                                  :groupRoleOptions="groupRoleOptions" />
        </ContentSection>
    </ContentSectionContainer>
</template>


<script setup lang="ts">
    import { computed, PropType, ref, watch } from "vue";
    import TransitionVerticalCollapse from "@Obsidian/Controls/transitionVerticalCollapse.obs";
    import { useStore } from "@Obsidian/PageState";
