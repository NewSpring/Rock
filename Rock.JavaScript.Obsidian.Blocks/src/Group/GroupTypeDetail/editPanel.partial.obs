    import { GroupLocationPickerMode, GroupLocationPickerModeDescription } from "@Obsidian/Enums/Group/groupLocationPickerMode";
    import RadioButtonList from "@Obsidian/Controls/radioButtonList.obs";
    import { GroupCapacityRule, GroupCapacityRuleDescription } from "@Obsidian/Enums/Group/groupCapacityRule";
    import CheckBox from "@Obsidian/Controls/checkBox.obs";
    import RockLabel from "@Obsidian/Controls/rockLabel.obs";
    import DropDownList from "@Obsidian/Controls/dropDownList.obs";
    import NumberBox from "@Obsidian/Controls/numberBox.obs";
    import HtmlEditor from "@Obsidian/Controls/htmlEditor.obs";
    import GroupTypeRoles from "./roles.partial.obs";
    import GroupAttributes from "./groupAttributes.partial.obs";
    import GroupMemberAttributes from "./groupMemberAttributes.partial.obs";
    import GroupTypeAttributes from "./groupTypeAttributes.partial.obs";
    import { GroupTypeInheritedAttributeBag } from "@Obsidian/ViewModels/Blocks/Group/GroupTypeDetail/groupTypeInheritedAttributeBag";
    import { GetInheritedAttributesResponseBag } from "@Obsidian/ViewModels/Blocks/Group/GroupTypeDetail/getInheritedAttributesResponseBag";
    import { emptyGuid, newGuid } from "@Obsidian/Utility/guid";
    import WorkflowTypePicker from "@Obsidian/Controls/workflowTypePicker.obs";
    import InlineSwitch from "@Obsidian/Controls/inlineSwitch.obs";
    import { ScheduleConfirmationLogic, ScheduleConfirmationLogicDescription } from "@Obsidian/Enums/Group/scheduleConfirmationLogic";
    import { ScheduleCoordinatorNotificationType, ScheduleCoordinatorNotificationTypeDescription } from "@Obsidian/Enums/Group/scheduleCoordinatorNotificationType";
    import { RelationshipStrength, RelationshipStrengthDescription } from "@Obsidian/Enums/Group/relationshipStrength";
    import { ScheduleType, ScheduleTypeDescription } from "@Obsidian/Enums/Group/scheduleType";
    import Grid, { TextColumn, DeleteColumn, EditColumn } from "@Obsidian/Controls/grid";
    import Modal from "@Obsidian/Controls/modal.obs";
    import DateRangePicker from "@Obsidian/Controls/dateRangePicker.obs";
    import { DateRangeParts } from "@Obsidian/Types/Controls/dateRangePicker";
    import { AlertType } from "@Obsidian/Enums/Controls/alertType";
    import { GroupTypeGroupScheduleExclusionBag } from "@Obsidian/ViewModels/Blocks/Group/GroupTypeDetail/groupTypeGroupScheduleExclusionBag";
    import { CanDeleteRequestBag } from "@Obsidian/ViewModels/Blocks/Group/GroupTypeDetail/canDeleteRequestBag";
    import { CanDeleteResponseBag } from "@Obsidian/ViewModels/Blocks/Group/GroupTypeDetail/canDeleteResponseBag";
    import { RockDateTime } from "@Obsidian/Utility/rockDateTime";
    import { ListItemBag } from "@Obsidian/ViewModels/Utility/listItemBag";
    import { ChatNotificationMode, ChatNotificationModeDescription } from "@Obsidian/Enums/Communication/Chat/chatNotificationMode";
    import GroupRequirements from "./groupRequirements.partial.obs";
    import GroupMemberWorkflows from "./groupMemberWorkflows.partial.obs";
    import { EntityKey } from "./types.partial";
    import { pluralize } from "@Obsidian/Utility/stringUtils";
    import { decimalToPercentage, percentageToDecimal } from "./utility.partial";

    const props = defineProps({
        modelValue: {
            type: Object as PropType<ValidPropertiesBox<GroupTypeBag>>,
            required: true
        },

        options: {
            type: Object as PropType<GroupTypeDetailOptionsBag>,
            required: true
        }
    });

    const emit = defineEmits<{
        (e: "update:modelValue", value: ValidPropertiesBox<GroupTypeBag>): void,
        (e: "propertyChanged", value: string): void
    }>();

    // #region Values

    const invokeBlockAction = useInvokeBlockAction();
    const store = useStore();
    const isSystem = ref(props.modelValue.bag?.isSystem ?? false);
    const isChatEnabledSystem = ref(props.options.isChatEnabledSystem ?? false);
    const errorMessage = ref<string | null>(null);
    const chatChannelsDisabledMessage = ref<string | null>(null);

    // GENERAL
    const name = propertyRef(props.modelValue.bag?.name ?? "", "Name");
    const description = propertyRef(props.modelValue.bag?.description ?? "", "Description");
    const groupTypeColor = propertyRef(props.modelValue.bag?.groupTypeColor ?? "", "GroupTypeColor");
    const iconCssClass = propertyRef(props.modelValue.bag?.iconCssClass ?? "", "IconCssClass");
    const groupTypePurposeValue = propertyRef(props.modelValue.bag?.groupTypePurposeValue ?? null, "GroupTypePurposeValueId");
    const inheritedGroupType = propertyRef(props.modelValue.bag?.inheritedGroupType ?? null, "InheritedGroupTypeId");
    const allowAnyChildGroupType = propertyRef(props.modelValue.bag?.allowAnyChildGroupType ?? false, "AllowAnyChildGroupType");
    const childGroupTypes = propertyRef(props.modelValue.bag?.childGroupTypes ?? [], "ChildGroupTypes");
    const groupsRequireCampus = propertyRef(props.modelValue.bag?.groupsRequireCampus ?? false, "GroupsRequireCampus");
    const showAdministrator = propertyRef(props.modelValue.bag?.showAdministrator ?? false, "ShowAdministrator");
    const enableSpecificGroupRequirements = propertyRef(props.modelValue.bag?.enableSpecificGroupRequirements ?? false, "EnableSpecificGroupRequirements");
    const locationSelectionMode = propertyRef(props.modelValue.bag?.locationSelectionMode ?? GroupLocationPickerMode.None, "LocationSelectionMode");
    const locationTypes = propertyRef(props.modelValue.bag?.locationTypes ?? [], "LocationTypes");
    const allowMultipleLocations = propertyRef(props.modelValue.bag?.allowMultipleLocations ?? false, "AllowMultipleLocations");
    const enableLocationSchedules = propertyRef(props.modelValue.bag?.enableLocationSchedules ?? false, "EnableLocationSchedules");
    const groupCapacityRule = propertyRef(props.modelValue.bag?.groupCapacityRule ?? 0, "GroupCapacityRule");
    const isCapacityRequired = propertyRef(props.modelValue.bag?.isCapacityRequired ?? false, "IsCapacityRequired");
    const groupStatusDefinedType = propertyRef(props.modelValue.bag?.groupStatusDefinedType ?? null, "GroupStatusDefinedType");
    const groupMemberRecordSourceValue = propertyRef(props.modelValue.bag?.groupMemberRecordSourceValue ?? null, "GroupMemberRecordSourceValue");
    const allowGroupSpecificRecordSource = propertyRef(props.modelValue.bag?.allowGroupSpecificRecordSource ?? false, "AllowGroupSpecificRecordSource");
    const allowSpecificGroupMemberAttributes = propertyRef(props.modelValue.bag?.allowSpecificGroupMemberAttributes ?? false, "AllowSpecificGroupMemberAttributes");
    const allowSpecificGroupMemberWorkflows = propertyRef(props.modelValue.bag?.allowSpecificGroupMemberWorkflows ?? false, "AllowSpecificGroupMemberWorkflows");
    const enableGroupTag = propertyRef(props.modelValue.bag?.enableGroupTag ?? false, "EnableGroupTag");
    const ignorePersonInactivated = propertyRef(props.modelValue.bag?.ignorePersonInactivated ?? false, "IgnorePersonInactivated");
    const isIndexEnabled = propertyRef(props.modelValue.bag?.isIndexEnabled ?? false, "IsIndexEnabled");
    const enableGroupHistory = propertyRef(props.modelValue.bag?.enableGroupHistory ?? false, "EnableGroupHistory");
    const allowGroupSync = propertyRef(props.modelValue.bag?.allowGroupSync ?? false, "AllowGroupSync");
    const enableInactiveReason = propertyRef(props.modelValue.bag?.enableInactiveReason ?? false, "EnableInactiveReason");
    const requiresInactiveReason = propertyRef(props.modelValue.bag?.requiresInactiveReason ?? false, "RequiresInactiveReason");

    // DISPLAY OPTIONS
    const groupTerm = propertyRef(props.modelValue.bag?.groupTerm ?? "", "GroupTerm");
    const groupMemberTerm = propertyRef(props.modelValue.bag?.groupMemberTerm ?? "", "GroupMemberTerm");
    const administratorTerm = propertyRef(props.modelValue.bag?.administratorTerm ?? "", "AdministratorTerm");
    const showInGroupList = propertyRef(props.modelValue.bag?.showInGroupList ?? false, "ShowInGroupList");
    const showInNavigation = propertyRef(props.modelValue.bag?.showInNavigation ?? false, "ShowInNavigation");
    const showConnectionStatus = propertyRef(props.modelValue.bag?.showConnectionStatus ?? false, "ShowConnectionStatus");
    const showMaritalStatus = propertyRef(props.modelValue.bag?.showMaritalStatus ?? false, "ShowMaritalStatus");
    const groupViewLavaTemplate = propertyRef(props.modelValue.bag?.groupViewLavaTemplate ?? "", "GroupViewLavaTemplate");

    // ROLES
    const roles = propertyRef(props.modelValue.bag?.roles ?? [], "Roles");
    const defaultGroupRole = propertyRef(props.modelValue.bag?.defaultGroupRole ?? null, "DefaultGroupRole");

    // ATTRIBUTE SECTIONS
    const attributes = ref(props.modelValue.bag?.attributes ?? {});
    const attributeValues = ref(props.modelValue.bag?.attributeValues ?? {});
    const groupAttributes = ref(props.modelValue.bag?.groupAttributes ?? []);
    const groupMemberAttributes = ref(props.modelValue.bag?.groupMemberAttributes ?? []);
    const groupTypeAttributes = ref(props.modelValue.bag?.groupTypeAttributes ?? []);
    const inheritedGroupMemberAttributes = ref<GroupTypeInheritedAttributeBag[]>([]);
    const inheritedGroupAttributes = ref<GroupTypeInheritedAttributeBag[]>([]);
    const inheritedGroupTypeAttributes = ref<GroupTypeInheritedAttributeBag[]>([]);

    // SCHEDULING
    const isSchedulingEnabled = propertyRef(props.modelValue.bag?.isSchedulingEnabled ?? false, "IsSchedulingEnabled");
    const scheduleConfirmationSystemCommunication = propertyRef(props.modelValue.bag?.scheduleConfirmationSystemCommunication ?? null, "ScheduleConfirmationSystemCommunication");
    const requiresReasonIfDeclineSchedule = propertyRef(props.modelValue.bag?.requiresReasonIfDeclineSchedule ?? false, "RequiresReasonIfDeclineSchedule");
    const scheduleConfirmationEmailOffsetDays = propertyRef(props.modelValue.bag?.scheduleConfirmationEmailOffsetDays ?? 4, "ScheduleConfirmationEmailOffsetDays");
    const scheduleConfirmationLogic = propertyRef(props.modelValue.bag?.scheduleConfirmationLogic ?? ScheduleConfirmationLogic.Ask, "ScheduleConfirmationLogic");
    const scheduleCoordinatorNotificationTypes = propertyRef(props.modelValue.bag?.scheduleCoordinatorNotificationTypes ?? ScheduleCoordinatorNotificationType.None, "ScheduleCoordinatorNotificationTypes");
    const scheduleReminderSystemCommunication = propertyRef(props.modelValue.bag?.scheduleReminderSystemCommunication ?? null, "ScheduleReminderSystemCommunication");
    const scheduleReminderEmailOffsetDays = propertyRef(props.modelValue.bag?.scheduleReminderEmailOffsetDays ?? 2, "ScheduleReminderEmailOffsetDays");
    const scheduleCancellationWorkflowType = propertyRef(props.modelValue.bag?.scheduleCancellationWorkflowType ?? null, "ScheduleCancellationWorkflowType");

    // PEER NETWORK
    const isPeerNetworkEnabled = propertyRef(props.modelValue.bag?.isPeerNetworkEnabled ?? false, "IsPeerNetworkEnabled");
    const relationshipStrength = propertyRef(props.modelValue.bag?.relationshipStrength ?? 0, "RelationshipStrength");
    const relationshipGrowthEnabled = propertyRef(props.modelValue.bag?.relationshipGrowthEnabled ?? false, "RelationshipGrowthEnabled");
    const leaderToLeaderRelationshipMultiplier = propertyRef(props.modelValue.bag?.leaderToLeaderRelationshipMultiplier ?? 1.00, "LeaderToLeaderRelationshipMultiplier");
    const leaderToNonLeaderRelationshipMultiplier = propertyRef(props.modelValue.bag?.leaderToNonLeaderRelationshipMultiplier ?? 1.00, "LeaderToNonLeaderRelationshipMultiplier");
    const nonLeaderToLeaderRelationshipMultiplier = propertyRef(props.modelValue.bag?.nonLeaderToLeaderRelationshipMultiplier ?? 1.00, "NonLeaderToLeaderRelationshipMultiplier");
    const nonLeaderToNonLeaderRelationshipMultiplier = propertyRef(props.modelValue.bag?.nonLeaderToNonLeaderRelationshipMultiplier ?? 1.00, "NonLeaderToNonLeaderRelationshipMultiplier");

    // ATTENDANCE
    const takesAttendance = propertyRef(props.modelValue.bag?.takesAttendance ?? false, "TakesAttendance");
    const allowedScheduleTypes = propertyRef(props.modelValue.bag?.allowedScheduleTypes ?? ScheduleType.None, "AllowedScheduleTypes");
    const scheduleExclusions = propertyRef(props.modelValue.bag?.scheduleExclusions ?? [], "ScheduleExclusions");
    const editingScheduleExclusion = ref<GroupTypeGroupScheduleExclusionBag>(createNewScheduleExclusion());
    const isScheduleExclusionModalVisible = ref(false);
    const isEditingScheduleExclusion = ref<boolean>(false);
    const scheduleExclusionsErrorMessage = ref<string | null>(null);
    const attendanceCountsAsWeekendService = propertyRef(props.modelValue.bag?.attendanceCountsAsWeekendService ?? false, "AttendanceCountsAsWeekendService");
    const groupAttendanceRequiresLocation = propertyRef(props.modelValue.bag?.groupAttendanceRequiresLocation ?? false, "GroupAttendanceRequiresLocation");
    const groupAttendanceRequiresSchedule = propertyRef(props.modelValue.bag?.groupAttendanceRequiresSchedule ?? false, "GroupAttendanceRequiresSchedule");
    const sendAttendanceReminder = propertyRef(props.modelValue.bag?.sendAttendanceReminder ?? false, "SendAttendanceReminder");
    const attendanceReminderSystemCommunication = propertyRef(props.modelValue.bag?.attendanceReminderSystemCommunication ?? null, "AttendanceReminderSystemCommunication");
    const attendanceReminderSendStartOffsetMinutes = propertyRef(props.modelValue.bag?.attendanceReminderSendStartOffsetMinutes ?? null, "AttendanceReminderSendStartOffsetMinutes");
    const attendanceReminderFollowupDays = propertyRef(props.modelValue.bag?.attendanceReminderFollowupDays ?? null, "AttendanceReminderFollowupDays");

    // RSVP
    const enableRSVP = propertyRef(props.modelValue.bag?.enableRSVP ?? false, "EnableRSVP");
    const rsvpReminderSystemCommunication = propertyRef(props.modelValue.bag?.rsvpReminderSystemCommunication ?? null, "RSVPReminderSystemCommunication");
    const rsvpReminderOffsetDays = propertyRef(props.modelValue.bag?.rsvpReminderOffsetDays ?? 0, "RSVPReminderOffsetDays");

    // CHAT
    const isChatAllowed = propertyRef(props.modelValue.bag?.isChatAllowed ?? false, "IsChatAllowed");
    const isChatEnabledForAllGroups = propertyRef(props.modelValue.bag?.isChatEnabledForAllGroups ?? false, "IsChatEnabledForAllGroups");
    const isLeavingChatChannelAllowed = propertyRef(props.modelValue.bag?.isLeavingChatChannelAllowed ?? false, "IsLeavingChatChannelAllowed");
    const isChatChannelPublic = propertyRef(props.modelValue.bag?.isChatChannelPublic ?? false, "IsChatChannelPublic");
    const isChatChannelAlwaysShown = propertyRef(props.modelValue.bag?.isChatChannelAlwaysShown ?? false, "IsChatChannelAlwaysShown");
    const chatPushNotificationMode = propertyRef(props.modelValue.bag?.chatPushNotificationMode ?? ChatNotificationMode.AllMessages, "ChatPushNotificationMode");

    // GROUP REQUIREMENTS
    const groupRequirements = propertyRef(props.modelValue.bag?.groupRequirements ?? null, "GroupRequirements");
    const groupRequirementTypeOptions = props.options.groupRequirementTypeOptions ?? [];

    // GROUP MEMBER WORKFLOWS
    const groupMemberWorkflowTriggers = propertyRef(props.modelValue.bag?.groupMemberWorkflowTriggers ?? null, "GroupMemberWorkflowTriggers");

    // The properties that are being edited. This should only contain
    // objects returned by propertyRef().
    const propRefs = [name, description, groupTypeColor, iconCssClass, groupTypePurposeValue, inheritedGroupType, allowAnyChildGroupType, childGroupTypes,
        groupsRequireCampus, showAdministrator, enableSpecificGroupRequirements, locationSelectionMode, locationTypes, allowMultipleLocations, enableLocationSchedules,
        groupCapacityRule, isCapacityRequired, groupStatusDefinedType, groupMemberRecordSourceValue, allowGroupSpecificRecordSource, allowSpecificGroupMemberAttributes,
        allowSpecificGroupMemberWorkflows, enableGroupTag, ignorePersonInactivated, isIndexEnabled, enableGroupHistory, allowGroupSync, enableInactiveReason, requiresInactiveReason,
        groupTerm, groupMemberTerm, administratorTerm, showInGroupList, showInNavigation, showConnectionStatus, showMaritalStatus, groupViewLavaTemplate, roles, defaultGroupRole,
        isSchedulingEnabled, scheduleConfirmationSystemCommunication, requiresReasonIfDeclineSchedule, scheduleConfirmationEmailOffsetDays, scheduleConfirmationLogic,
        scheduleCoordinatorNotificationTypes, scheduleReminderSystemCommunication, scheduleReminderEmailOffsetDays, scheduleCancellationWorkflowType, isPeerNetworkEnabled,
        relationshipStrength, relationshipGrowthEnabled, leaderToLeaderRelationshipMultiplier, leaderToNonLeaderRelationshipMultiplier, nonLeaderToLeaderRelationshipMultiplier, nonLeaderToNonLeaderRelationshipMultiplier,
        takesAttendance, allowedScheduleTypes, scheduleExclusions, attendanceCountsAsWeekendService, groupAttendanceRequiresLocation, groupAttendanceRequiresSchedule, sendAttendanceReminder,
        attendanceReminderSystemCommunication, attendanceReminderSendStartOffsetMinutes, attendanceReminderFollowupDays, enableRSVP, rsvpReminderSystemCommunication, rsvpReminderOffsetDays,
        isChatAllowed, isChatEnabledForAllGroups, isLeavingChatChannelAllowed, isChatChannelPublic, isChatChannelAlwaysShown, chatPushNotificationMode, groupRequirements, groupMemberWorkflowTriggers];

    // #endregion Values

    // #region Computed Values

    /**
     * Used to prevent selecting the current group type as its own inherited group type.
     */
    const excludedGroupTypes = computed((): string[] => {
        return props.modelValue.bag?.guid ? [props.modelValue.bag.guid] : [];
    });

    const groupStatusDefinedTypeValue = computed({
        get(): string {
            return groupStatusDefinedType.value?.value ?? "";
        },
        set(newValue: string) {
            const theText = props.options.definedTypeOptions?.find(dt => dt.value === newValue)?.text ?? "";
            groupStatusDefinedType.value = {
                value: newValue,
                text: theText
            };
        }
    });

    const locationSelectionModeValue = computed({
        get(): string[] {
            const value = locationSelectionMode.value ?? GroupLocationPickerMode.None;
            const values: string[] = [];

            if ((value & GroupLocationPickerMode.Address) === GroupLocationPickerMode.Address) {
                values.push(GroupLocationPickerMode.Address.toString());
            }

            if ((value & GroupLocationPickerMode.Named) === GroupLocationPickerMode.Named) {
                values.push(GroupLocationPickerMode.Named.toString());
            }

            if ((value & GroupLocationPickerMode.Point) === GroupLocationPickerMode.Point) {
                values.push(GroupLocationPickerMode.Point.toString());
            }

            if ((value & GroupLocationPickerMode.Polygon) === GroupLocationPickerMode.Polygon) {
                values.push(GroupLocationPickerMode.Polygon.toString());
            }

            if ((value & GroupLocationPickerMode.GroupMember) === GroupLocationPickerMode.GroupMember) {
                values.push(GroupLocationPickerMode.GroupMember.toString());
            }

            return values;
        },
        set(newValue: string[]) {
            let value = 0;

            for (const val of newValue) {
                value |= parseInt(val, 10);
            }

            locationSelectionMode.value = value as GroupLocationPickerMode;
        }
    });

    const locationSelectionModeOptions = enumToListItemBag(GroupLocationPickerModeDescription)
        .filter(item => item.value !== GroupLocationPickerMode.None.toString() && item.value !== GroupLocationPickerMode.All.toString())
        .map(item => {
            if (item.value === GroupLocationPickerMode.Polygon.toString()) {
                item.text = "Geo-fence";
            }

            return item;
        });

    const groupCapacityRuleValue = computed({
        get(): string {
            return (groupCapacityRule.value).toString();
        },
        set(newValue: string) {
            const value = parseInt(newValue, 10) as GroupCapacityRule;
            groupCapacityRule.value = value;

            if (value === GroupCapacityRule.None) {
                isCapacityRequired.value = false;
            }
        }
    });

    const enableInactiveReasonValue = computed({
        get(): boolean {
            return enableInactiveReason.value;
        },
        set(newValue: boolean) {
            enableInactiveReason.value = newValue;

            if (!newValue) {
                requiresInactiveReason.value = false;
            }
        }
    });

    const scheduleConfirmationLogicValue = computed({
        get(): string {
            return (scheduleConfirmationLogic.value ?? ScheduleConfirmationLogic.Ask).toString();
        },
        set(newValue: string) {
            scheduleConfirmationLogic.value = parseInt(newValue, 10) as ScheduleConfirmationLogic;
        }
    });

    const scheduleCoordinatorNotificationTypesValue = computed({
        get(): string[] {
            const value = scheduleCoordinatorNotificationTypes.value ?? ScheduleCoordinatorNotificationType.None;
            const values: string[] = [];

            if ((value & ScheduleCoordinatorNotificationType.Accept) === ScheduleCoordinatorNotificationType.Accept) {
                values.push(ScheduleCoordinatorNotificationType.Accept.toString());
            }

            if ((value & ScheduleCoordinatorNotificationType.Decline) === ScheduleCoordinatorNotificationType.Decline) {
                values.push(ScheduleCoordinatorNotificationType.Decline.toString());
            }

            if ((value & ScheduleCoordinatorNotificationType.SelfSchedule) === ScheduleCoordinatorNotificationType.SelfSchedule) {
                values.push(ScheduleCoordinatorNotificationType.SelfSchedule.toString());
            }

            return values;
        },
        set(newValue: string[]) {
            let value = 0;

            for (const val of newValue) {
                value |= parseInt(val, 10);
            }

            scheduleCoordinatorNotificationTypes.value = value as ScheduleCoordinatorNotificationType;
        }
    });


    const scheduleCoordinatorNotificationTypesOptions = enumToListItemBag(ScheduleCoordinatorNotificationTypeDescription)
        .filter(item => item.value !== ScheduleCoordinatorNotificationType.None.toString());

    const schedulingSectionTitle = computed((): string => {
        if (isSchedulingEnabled.value) {
            return "Scheduling Feature";
        }
        else {
            return "Confirmation Settings";
        }
    });

    const schedulingSectionDescription = computed((): string => {
        if (isSchedulingEnabled.value) {
            return "Enable groups of this type to schedule and remind members of upcoming events.";
        }
        else {
            return "Controls how and when group members are notified about their scheduled assignments, including confirmation messages and coordinator notifications.";
        }
    });

    const peerNetworkSectionDescription = computed((): string => {
        if (isPeerNetworkEnabled.value) {
            return "Enable groups of this type to build peer network relationships among their members.";
        }
        else {
            return "Enable the ability to add Peer Network features for groups of this type, including managing relationships.";
        }
    });

    const relationshipStrengthValue = computed({
        get(): string {
            return (relationshipStrength.value ?? RelationshipStrength.None).toString();
        },
        set(newValue: string) {
            relationshipStrength.value = parseInt(newValue, 10) as RelationshipStrength;
        }
    });

    /**
     * Relationship multipliers are stored as a decimal value (0.00 - 1.00) in the model,
     * but edited as a percentage (0 - 100) in the UI.
     */
    const leaderToLeaderRelationshipMultiplierValue = computed({
        get(): number | null {
            return decimalToPercentage(leaderToLeaderRelationshipMultiplier.value);
        },
        set(newValue: number | null) {
            leaderToLeaderRelationshipMultiplier.value = percentageToDecimal(newValue);
        }
    });

    const leaderToNonLeaderRelationshipMultiplierValue = computed({
        get(): number | null {
            return decimalToPercentage(leaderToNonLeaderRelationshipMultiplier.value);
        },
        set(newValue: number | null) {
            leaderToNonLeaderRelationshipMultiplier.value = percentageToDecimal(newValue);
        }
    });

    const nonLeaderToLeaderRelationshipMultiplierValue = computed({
        get(): number | null {
            return decimalToPercentage(nonLeaderToLeaderRelationshipMultiplier.value);
        },
        set(newValue: number | null) {
            nonLeaderToLeaderRelationshipMultiplier.value = percentageToDecimal(newValue);
        }
    });

    const nonLeaderToNonLeaderRelationshipMultiplierValue = computed({
        get(): number | null {
            return decimalToPercentage(nonLeaderToNonLeaderRelationshipMultiplier.value);
        },
        set(newValue: number | null) {
            nonLeaderToNonLeaderRelationshipMultiplier.value = percentageToDecimal(newValue);
        }
    });

    const allowedScheduleTypesValue = computed({
        get(): string[] {
            const value = allowedScheduleTypes.value ?? ScheduleType.None;
            const values: string[] = [];

            if ((value & ScheduleType.Weekly) === ScheduleType.Weekly) {
                values.push(ScheduleType.Weekly.toString());
            }

            if ((value & ScheduleType.Custom) === ScheduleType.Custom) {
                values.push(ScheduleType.Custom.toString());
            }

            if ((value & ScheduleType.Named) === ScheduleType.Named) {
                values.push(ScheduleType.Named.toString());
            }

            return values;
        },
        set(newValue: string[]) {
            let value = 0;

            for (const val of newValue) {
                value |= parseInt(val, 10);
            }

            allowedScheduleTypes.value = value as ScheduleType;
        }
    });

    const allowedScheduleTypesOptions = enumToListItemBag(ScheduleTypeDescription)
        .filter(item => item.value !== ScheduleType.None.toString());

    const groupScheduleExclusionsGridData = computed(() => {
        const rows = (scheduleExclusions.value ?? []).map(s => {
            const start = s.startDate ? RockDateTime.parseISO(s.startDate)?.toASPString("MM/dd/yyyy") ?? "" : "";
            const end = s.endDate ? RockDateTime.parseISO(s.endDate)?.toASPString("MM/dd/yyyy") ?? "" : "";
            return {
                guid: s.guid,
                dateRange: `${start} - ${end}`
            };
        });

        return { rows };
    });

    const editingScheduleExclusionDateRange = computed<DateRangeParts | undefined>({
        get() {
            if (!editingScheduleExclusion.value.startDate && !editingScheduleExclusion.value.endDate) {
                return undefined;
            }

            return {
                lowerValue: editingScheduleExclusion.value.startDate || "",
                upperValue: editingScheduleExclusion.value.endDate || ""
            };
        },
        set(newValue) {
            editingScheduleExclusion.value.startDate = newValue?.lowerValue || null;
            editingScheduleExclusion.value.endDate = newValue?.upperValue || null;
        }
    });

    const attendanceReminderFollowupDaysValue = computed({
        get(): string[] {
            return (attendanceReminderFollowupDays.value ?? []).map(val => val.toString());
        },
        set(newValue: string[]) {
            attendanceReminderFollowupDays.value = newValue.map(val => parseInt(val, 10));
        }
    });

    const attendanceReminderFollowupDaysOptions: ListItemBag[] = [
        { value: "1", text: "1 Day After" },
        { value: "2", text: "2 Days After" },
        { value: "3", text: "3 Days After" },
        { value: "4", text: "4 Days After" },
        { value: "5", text: "5 Days After" },
        { value: "6", text: "6 Days After" },
        { value: "7", text: "7 Days After" },
    ];

    const chatPushNotificationModeValue = computed({
        get(): string {
            return (chatPushNotificationMode.value ?? ChatNotificationMode.AllMessages).toString();
        },
        set(newValue: string) {
            chatPushNotificationMode.value = parseInt(newValue, 10) as ChatNotificationMode;
        }
    });

    /**
     * System Communication pickers are stored as ListItemBag (value + text) in the model,
     * but edited as a Guid string via a dropdown list.
     */
    const scheduleConfirmationSystemCommunicationGuid = computed({
        get(): string {
            return scheduleConfirmationSystemCommunication.value?.value ?? "";
        },
        set(newValue: string) {
            if (!newValue) {
                scheduleConfirmationSystemCommunication.value = null;
                return;
            }

            const item = (props.options.systemCommunicationOptions ?? []).find(i => (i.value ?? "") === newValue) ?? null;
            scheduleConfirmationSystemCommunication.value = item
                ? { value: item.value ?? "", text: item.text ?? "" }
                : null;
        }
    });

    const scheduleReminderSystemCommunicationGuid = computed({
        get(): string {
            return scheduleReminderSystemCommunication.value?.value ?? "";
        },
        set(newValue: string) {
            if (!newValue) {
                scheduleReminderSystemCommunication.value = null;
                return;
            }

            const item = (props.options.systemCommunicationOptions ?? []).find(i => (i.value ?? "") === newValue) ?? null;
            scheduleReminderSystemCommunication.value = item
                ? { value: item.value ?? "", text: item.text ?? "" }
                : null;
        }
    });

    const attendanceReminderSystemCommunicationGuid = computed({
        get(): string {
            return attendanceReminderSystemCommunication.value?.value ?? "";
        },
        set(newValue: string) {
            if (!newValue) {
                attendanceReminderSystemCommunication.value = null;
                return;
            }

            const item = (props.options.systemCommunicationOptions ?? []).find(i => (i.value ?? "") === newValue) ?? null;
            attendanceReminderSystemCommunication.value = item
                ? { value: item.value ?? "", text: item.text ?? "" }
                : null;
        }
    });

    const rsvpReminderSystemCommunicationGuid = computed({
        get(): string {
            return rsvpReminderSystemCommunication.value?.value ?? "";
        },
        set(newValue: string) {
            if (!newValue) {
                rsvpReminderSystemCommunication.value = null;
                return;
            }

            const item = (props.options.rsvpSystemCommunicationOptions ?? []).find(i => (i.value ?? "") === newValue) ?? null;
            rsvpReminderSystemCommunication.value = item
                ? { value: item.value ?? "", text: item.text ?? "" }
                : null;
        }
    });

    const groupRoleOptions = computed<ListItemBag[]>(() => {
        return (roles.value ?? []).map(r => ({
            value: r.guid,
            text: r.name
        }));
    });

    const groupAttributeOptions = computed<ListItemBag[]>(() => {
        return (groupAttributes.value ?? []).map(a => ({
            value: a.guid,
            text: a.name
        }));
    });

    const groupRequirementRoles = computed((): string[] => {
        return (groupRequirements.value ?? [])
            .map(r => r.role?.value)
            .filter(r => r) as string[];
    });

    const workflowTriggerRoles = computed((): string[] => {
        const roles: string[] = [];
        (groupMemberWorkflowTriggers.value ?? []).forEach(t => {
            if (t.toRoleGuid) roles.push(t.toRoleGuid);
            if (t.fromRoleGuid) roles.push(t.fromRoleGuid);
        });

        return roles;
    });

    // #endregion Computed Values

    // #region Functions

    /**
     * Loads inherited group, group member, and group type attributes based on the currently-selected
     * "Inherited Group Type" value.
     */
    async function loadAttributesForGroupType(): Promise<void> {
        const inheritedGroupTypeGuid = inheritedGroupType.value?.value ?? emptyGuid;

        const result = await invokeBlockAction<GetInheritedAttributesResponseBag>("GetInheritedAttributes", {
            inheritedGroupTypeGuid
        });

        if (!result.isSuccess || !result.data) {
            errorMessage.value = result.errorMessage || "Failed to load any related attributes for this group type.";
            return;
        }

        if (result.data) {
            inheritedGroupAttributes.value = result.data.inheritedGroupAttributes ?? [];
            inheritedGroupMemberAttributes.value = result.data.inheritedGroupMemberAttributes ?? [];
            inheritedGroupTypeAttributes.value = result.data.inheritedGroupTypeAttributes ?? [];
        }
    }

    /**
     * Creates a new schedule exclusion record for the grid and edit modal.
     */
    function createNewScheduleExclusion(): GroupTypeGroupScheduleExclusionBag {
        return {
            guid: newGuid(),
            startDate: null,
            endDate: null
        };
    }

    /**
     * Called when the Add Schedule Exclusion button is clicked.
     */
    function onAddScheduleExclusion(): void {
        isEditingScheduleExclusion.value = false;
        scheduleExclusionsErrorMessage.value = null;
        editingScheduleExclusion.value = createNewScheduleExclusion();

        isScheduleExclusionModalVisible.value = true;
    }

    /**
     * Called when the Edit button for a schedule exclusion row is clicked.
     *
     * @param guid The unique identifier of the schedule exclusion to edit.
     */
    function onEditScheduleExclusion(guid: string): void {
        const exclusion = scheduleExclusions.value.find(e => e.guid === guid);

        if (!exclusion) {
            return;
        }

        isEditingScheduleExclusion.value = true;
        editingScheduleExclusion.value = { ...exclusion };
        scheduleExclusionsErrorMessage.value = null;
        isScheduleExclusionModalVisible.value = true;
    }

    /**
     * Called when the Delete button for a schedule exclusion row is clicked.
     *
     * @param guid The unique identifier of the schedule exclusion to delete.
     */
    async function onDeleteScheduleExclusion(guid: string): Promise<void> {
        const result = await invokeBlockAction<CanDeleteResponseBag>("CanDeleteEntity", {
            request: {
                entityKey: EntityKey.ScheduleExclusion,
                entityGuid: guid
            } as CanDeleteRequestBag
        });

        if (!result.isSuccess || !result.data) {
            scheduleExclusionsErrorMessage.value = result.errorMessage || "Unable to delete this schedule exclusion.";
            return;
        }

        if (!result.data.canDelete) {
            scheduleExclusionsErrorMessage.value = result.data.errorMessage || "This schedule exclusion cannot be deleted.";
            return;
        }

        const updatedExclusions = scheduleExclusions.value.filter(e => e.guid !== guid);
        scheduleExclusions.value = updatedExclusions;
        scheduleExclusionsErrorMessage.value = null;
    }

    /**
     * Called when the schedule exclusion modal Save button is clicked.
     * Validates the date range and then updates the backing list.
     */
    function onSaveScheduleExclusion(): void {
        const startDate = editingScheduleExclusion.value.startDate;
        const endDate = editingScheduleExclusion.value.endDate;

        if (!startDate || !endDate) {
            scheduleExclusionsErrorMessage.value = "Both start and end dates are required for a schedule exclusion.";
            isScheduleExclusionModalVisible.value = false;
            return;
        }

        if (RockDateTime.parseISO(startDate)! > RockDateTime.parseISO(endDate)!) {
            scheduleExclusionsErrorMessage.value = "The start date for a schedule exclusion cannot be after the end date.";
            isScheduleExclusionModalVisible.value = false;
            return;
        }

        const currentExclusions = [...scheduleExclusions.value];
        const index = currentExclusions.findIndex(e => e.guid === editingScheduleExclusion.value.guid);

        let updatedExclusions: GroupTypeGroupScheduleExclusionBag[];
        if (index >= 0) {
            updatedExclusions = [...currentExclusions];
            updatedExclusions.splice(index, 1, { ...editingScheduleExclusion.value });
        }
        else {
            updatedExclusions = [...currentExclusions, { ...editingScheduleExclusion.value }];
        }

        // Sort by start date
        updatedExclusions.sort((a, b) => {
            const dateA = new Date(a.startDate || 0).getTime();
            const dateB = new Date(b.startDate || 0).getTime();
            return dateA - dateB;
        });

        scheduleExclusions.value = updatedExclusions;
        scheduleExclusionsErrorMessage.value = null;
        isScheduleExclusionModalVisible.value = false;
    }

    // #endregion Functions

    // Watch for parental changes in our model value and update all our values.
    watch(() => props.modelValue, () => {

        // GENERAL
        updateRefValue(name, props.modelValue.bag?.name ?? "");
        updateRefValue(description, props.modelValue.bag?.description ?? "");
        updateRefValue(groupTypeColor, props.modelValue.bag?.groupTypeColor ?? "");
        updateRefValue(iconCssClass, props.modelValue.bag?.iconCssClass ?? "");
        updateRefValue(groupTypePurposeValue, props.modelValue.bag?.groupTypePurposeValue ?? null);
        updateRefValue(inheritedGroupType, props.modelValue.bag?.inheritedGroupType ?? null);
        updateRefValue(allowAnyChildGroupType, props.modelValue.bag?.allowAnyChildGroupType ?? false);
        updateRefValue(childGroupTypes, props.modelValue.bag?.childGroupTypes ?? []);
        updateRefValue(groupsRequireCampus, props.modelValue.bag?.groupsRequireCampus ?? false);
        updateRefValue(showAdministrator, props.modelValue.bag?.showAdministrator ?? false);
        updateRefValue(enableSpecificGroupRequirements, props.modelValue.bag?.enableSpecificGroupRequirements ?? false);
        updateRefValue(locationSelectionMode, props.modelValue.bag?.locationSelectionMode ?? GroupLocationPickerMode.None);
        updateRefValue(locationTypes, props.modelValue.bag?.locationTypes ?? []);
        updateRefValue(allowMultipleLocations, props.modelValue.bag?.allowMultipleLocations ?? false);
        updateRefValue(enableLocationSchedules, props.modelValue.bag?.enableLocationSchedules ?? false);
        updateRefValue(groupCapacityRule, props.modelValue.bag?.groupCapacityRule ?? 0);
        updateRefValue(isCapacityRequired, props.modelValue.bag?.isCapacityRequired ?? false);
        updateRefValue(groupStatusDefinedType, props.modelValue.bag?.groupStatusDefinedType ?? null);
        updateRefValue(groupMemberRecordSourceValue, props.modelValue.bag?.groupMemberRecordSourceValue ?? null);
        updateRefValue(allowGroupSpecificRecordSource, props.modelValue.bag?.allowGroupSpecificRecordSource ?? false);
        updateRefValue(allowSpecificGroupMemberAttributes, props.modelValue.bag?.allowSpecificGroupMemberAttributes ?? false);
        updateRefValue(allowSpecificGroupMemberWorkflows, props.modelValue.bag?.allowSpecificGroupMemberWorkflows ?? false);
        updateRefValue(enableGroupTag, props.modelValue.bag?.enableGroupTag ?? false);
        updateRefValue(ignorePersonInactivated, props.modelValue.bag?.ignorePersonInactivated ?? false);
        updateRefValue(isIndexEnabled, props.modelValue.bag?.isIndexEnabled ?? false);
        updateRefValue(enableGroupHistory, props.modelValue.bag?.enableGroupHistory ?? false);
        updateRefValue(allowGroupSync, props.modelValue.bag?.allowGroupSync ?? false);
        updateRefValue(enableInactiveReason, props.modelValue.bag?.enableInactiveReason ?? false);
        updateRefValue(requiresInactiveReason, props.modelValue.bag?.requiresInactiveReason ?? false);

        // DISPLAY OPTIONS
        updateRefValue(groupTerm, props.modelValue.bag?.groupTerm ?? "");
        updateRefValue(groupMemberTerm, props.modelValue.bag?.groupMemberTerm ?? "");
        updateRefValue(administratorTerm, props.modelValue.bag?.administratorTerm ?? "");
        updateRefValue(showInGroupList, props.modelValue.bag?.showInGroupList ?? false);
        updateRefValue(showInNavigation, props.modelValue.bag?.showInNavigation ?? false);
        updateRefValue(showConnectionStatus, props.modelValue.bag?.showConnectionStatus ?? false);
        updateRefValue(showMaritalStatus, props.modelValue.bag?.showMaritalStatus ?? false);
        updateRefValue(groupViewLavaTemplate, props.modelValue.bag?.groupViewLavaTemplate ?? "");

        // ROLES
        updateRefValue(roles, props.modelValue.bag?.roles ?? []);
        updateRefValue(defaultGroupRole, props.modelValue.bag?.defaultGroupRole ?? null);

        // ATTRIBUTE SECTIONS
        updateRefValue(attributes, props.modelValue.bag?.attributes ?? {});
        updateRefValue(attributeValues, props.modelValue.bag?.attributeValues ?? {});
        updateRefValue(groupAttributes, props.modelValue.bag?.groupAttributes ?? []);
        updateRefValue(groupMemberAttributes, props.modelValue.bag?.groupMemberAttributes ?? []);
        updateRefValue(groupTypeAttributes, props.modelValue.bag?.groupTypeAttributes ?? []);

        // SCHEDULING
        updateRefValue(isSchedulingEnabled, props.modelValue.bag?.isSchedulingEnabled ?? false);
        updateRefValue(scheduleConfirmationSystemCommunication, props.modelValue.bag?.scheduleConfirmationSystemCommunication ?? null);
        updateRefValue(requiresReasonIfDeclineSchedule, props.modelValue.bag?.requiresReasonIfDeclineSchedule ?? false);
        updateRefValue(scheduleConfirmationEmailOffsetDays, props.modelValue.bag?.scheduleConfirmationEmailOffsetDays ?? 4);
        updateRefValue(scheduleConfirmationLogic, props.modelValue.bag?.scheduleConfirmationLogic ?? ScheduleConfirmationLogic.Ask);
        updateRefValue(scheduleCoordinatorNotificationTypes, props.modelValue.bag?.scheduleCoordinatorNotificationTypes ?? ScheduleCoordinatorNotificationType.None);
        updateRefValue(scheduleReminderSystemCommunication, props.modelValue.bag?.scheduleReminderSystemCommunication ?? null);
        updateRefValue(scheduleReminderEmailOffsetDays, props.modelValue.bag?.scheduleReminderEmailOffsetDays ?? 2);
        updateRefValue(scheduleCancellationWorkflowType, props.modelValue.bag?.scheduleCancellationWorkflowType ?? null);

        // PEER NETWORK
        updateRefValue(isPeerNetworkEnabled, props.modelValue.bag?.isPeerNetworkEnabled ?? false);
        updateRefValue(relationshipStrength, props.modelValue.bag?.relationshipStrength ?? 0);
        updateRefValue(relationshipGrowthEnabled, props.modelValue.bag?.relationshipGrowthEnabled ?? false);
        updateRefValue(leaderToLeaderRelationshipMultiplier, props.modelValue.bag?.leaderToLeaderRelationshipMultiplier ?? 1.00);
        updateRefValue(leaderToNonLeaderRelationshipMultiplier, props.modelValue.bag?.leaderToNonLeaderRelationshipMultiplier ?? 1.00);
        updateRefValue(nonLeaderToLeaderRelationshipMultiplier, props.modelValue.bag?.nonLeaderToLeaderRelationshipMultiplier ?? 1.00);
        updateRefValue(nonLeaderToNonLeaderRelationshipMultiplier, props.modelValue.bag?.nonLeaderToNonLeaderRelationshipMultiplier ?? 1.00);

        // ATTENDANCE
        updateRefValue(takesAttendance, props.modelValue.bag?.takesAttendance ?? false);
        updateRefValue(allowedScheduleTypes, props.modelValue.bag?.allowedScheduleTypes ?? ScheduleType.None);
        updateRefValue(scheduleExclusions, props.modelValue.bag?.scheduleExclusions ?? []);
        updateRefValue(attendanceCountsAsWeekendService, props.modelValue.bag?.attendanceCountsAsWeekendService ?? false);
        updateRefValue(groupAttendanceRequiresLocation, props.modelValue.bag?.groupAttendanceRequiresLocation ?? false);
        updateRefValue(groupAttendanceRequiresSchedule, props.modelValue.bag?.groupAttendanceRequiresSchedule ?? false);
        updateRefValue(sendAttendanceReminder, props.modelValue.bag?.sendAttendanceReminder ?? false);
        updateRefValue(attendanceReminderSystemCommunication, props.modelValue.bag?.attendanceReminderSystemCommunication ?? null);
        updateRefValue(attendanceReminderSendStartOffsetMinutes, props.modelValue.bag?.attendanceReminderSendStartOffsetMinutes ?? null);
        updateRefValue(attendanceReminderFollowupDays, props.modelValue.bag?.attendanceReminderFollowupDays ?? null);

        // RSVP
        updateRefValue(enableRSVP, props.modelValue.bag?.enableRSVP ?? false);
        updateRefValue(rsvpReminderSystemCommunication, props.modelValue.bag?.rsvpReminderSystemCommunication ?? null);
        updateRefValue(rsvpReminderOffsetDays, props.modelValue.bag?.rsvpReminderOffsetDays ?? 0);

        // CHAT
        updateRefValue(isChatAllowed, props.modelValue.bag?.isChatAllowed ?? false);
        updateRefValue(isChatEnabledForAllGroups, props.modelValue.bag?.isChatEnabledForAllGroups ?? false);
        updateRefValue(isLeavingChatChannelAllowed, props.modelValue.bag?.isLeavingChatChannelAllowed ?? false);
        updateRefValue(isChatChannelPublic, props.modelValue.bag?.isChatChannelPublic ?? false);
        updateRefValue(isChatChannelAlwaysShown, props.modelValue.bag?.isChatChannelAlwaysShown ?? false);
        updateRefValue(chatPushNotificationMode, props.modelValue.bag?.chatPushNotificationMode ?? ChatNotificationMode.AllMessages);

        // GROUP REQUIREMENTS
        updateRefValue(groupRequirements, props.modelValue.bag?.groupRequirements ?? null);

        // GROUP MEMBER WORKFLOWS
        updateRefValue(groupMemberWorkflowTriggers, props.modelValue.bag?.groupMemberWorkflowTriggers ?? null);

    });

    // Determines which values we want to track changes on (defined in the
    // array) and then emit a new object defined as newValue.
    watch([groupAttributes, groupMemberAttributes, groupTypeAttributes, attributeValues, ...propRefs], () => {
        const newValue: ValidPropertiesBox<GroupTypeBag> = {
            bag: { ...props.modelValue.bag } as GroupTypeBag
        };

        // GENERAL
        setPropertiesBoxValue(newValue, "name", name.value);
        setPropertiesBoxValue(newValue, "description", description.value);
        setPropertiesBoxValue(newValue, "groupTypeColor", groupTypeColor.value);
        setPropertiesBoxValue(newValue, "iconCssClass", iconCssClass.value);
        setPropertiesBoxValue(newValue, "groupTypePurposeValue", groupTypePurposeValue.value);
        setPropertiesBoxValue(newValue, "inheritedGroupType", inheritedGroupType.value);
        setPropertiesBoxValue(newValue, "allowAnyChildGroupType", allowAnyChildGroupType.value);
        setPropertiesBoxValue(newValue, "childGroupTypes", childGroupTypes.value);
        setPropertiesBoxValue(newValue, "groupsRequireCampus", groupsRequireCampus.value);
        setPropertiesBoxValue(newValue, "showAdministrator", showAdministrator.value);
        setPropertiesBoxValue(newValue, "enableSpecificGroupRequirements", enableSpecificGroupRequirements.value);
        setPropertiesBoxValue(newValue, "locationSelectionMode", locationSelectionMode.value);
        setPropertiesBoxValue(newValue, "locationTypes", locationTypes.value);
        setPropertiesBoxValue(newValue, "allowMultipleLocations", allowMultipleLocations.value);
        setPropertiesBoxValue(newValue, "enableLocationSchedules", enableLocationSchedules.value);
        setPropertiesBoxValue(newValue, "groupCapacityRule", groupCapacityRule.value);
        setPropertiesBoxValue(newValue, "isCapacityRequired", isCapacityRequired.value);
        setPropertiesBoxValue(newValue, "groupStatusDefinedType", groupStatusDefinedType.value);
        setPropertiesBoxValue(newValue, "groupMemberRecordSourceValue", groupMemberRecordSourceValue.value);
        setPropertiesBoxValue(newValue, "allowGroupSpecificRecordSource", allowGroupSpecificRecordSource.value);
        setPropertiesBoxValue(newValue, "allowSpecificGroupMemberAttributes", allowSpecificGroupMemberAttributes.value);
        setPropertiesBoxValue(newValue, "allowSpecificGroupMemberWorkflows", allowSpecificGroupMemberWorkflows.value);
        setPropertiesBoxValue(newValue, "enableGroupTag", enableGroupTag.value);
        setPropertiesBoxValue(newValue, "ignorePersonInactivated", ignorePersonInactivated.value);
        setPropertiesBoxValue(newValue, "isIndexEnabled", isIndexEnabled.value);
        setPropertiesBoxValue(newValue, "enableGroupHistory", enableGroupHistory.value);
        setPropertiesBoxValue(newValue, "allowGroupSync", allowGroupSync.value);
        setPropertiesBoxValue(newValue, "enableInactiveReason", enableInactiveReason.value);
        setPropertiesBoxValue(newValue, "requiresInactiveReason", requiresInactiveReason.value);

        // DISPLAY OPTIONS
        setPropertiesBoxValue(newValue, "groupTerm", groupTerm.value);
        setPropertiesBoxValue(newValue, "groupMemberTerm", groupMemberTerm.value);
        setPropertiesBoxValue(newValue, "administratorTerm", administratorTerm.value);
        setPropertiesBoxValue(newValue, "showInGroupList", showInGroupList.value);
        setPropertiesBoxValue(newValue, "showInNavigation", showInNavigation.value);
        setPropertiesBoxValue(newValue, "showConnectionStatus", showConnectionStatus.value);
        setPropertiesBoxValue(newValue, "showMaritalStatus", showMaritalStatus.value);
        setPropertiesBoxValue(newValue, "groupViewLavaTemplate", groupViewLavaTemplate.value);

        // ROLES
        setPropertiesBoxValue(newValue, "roles", roles.value);
        setPropertiesBoxValue(newValue, "defaultGroupRole", defaultGroupRole.value);

        // ATTRIBUTE SECTIONS
        setPropertiesBoxValue(newValue, "attributeValues", attributeValues.value);
        setPropertiesBoxValue(newValue, "groupAttributes", groupAttributes.value);
        setPropertiesBoxValue(newValue, "groupMemberAttributes", groupMemberAttributes.value);
        setPropertiesBoxValue(newValue, "groupTypeAttributes", groupTypeAttributes.value);

        // SCHEDULING
        setPropertiesBoxValue(newValue, "isSchedulingEnabled", isSchedulingEnabled.value);
        setPropertiesBoxValue(newValue, "scheduleConfirmationSystemCommunication", scheduleConfirmationSystemCommunication.value);
        setPropertiesBoxValue(newValue, "requiresReasonIfDeclineSchedule", requiresReasonIfDeclineSchedule.value);
        setPropertiesBoxValue(newValue, "scheduleConfirmationEmailOffsetDays", scheduleConfirmationEmailOffsetDays.value);
        setPropertiesBoxValue(newValue, "scheduleConfirmationLogic", scheduleConfirmationLogic.value);
        setPropertiesBoxValue(newValue, "scheduleCoordinatorNotificationTypes", scheduleCoordinatorNotificationTypes.value);
        setPropertiesBoxValue(newValue, "scheduleReminderSystemCommunication", scheduleReminderSystemCommunication.value);
        setPropertiesBoxValue(newValue, "scheduleReminderEmailOffsetDays", scheduleReminderEmailOffsetDays.value);
        setPropertiesBoxValue(newValue, "scheduleCancellationWorkflowType", scheduleCancellationWorkflowType.value);

        // PEER NETWORK
        setPropertiesBoxValue(newValue, "isPeerNetworkEnabled", isPeerNetworkEnabled.value);
        setPropertiesBoxValue(newValue, "relationshipStrength", relationshipStrength.value);
        setPropertiesBoxValue(newValue, "relationshipGrowthEnabled", relationshipGrowthEnabled.value);
        setPropertiesBoxValue(newValue, "leaderToLeaderRelationshipMultiplier", leaderToLeaderRelationshipMultiplier.value);
        setPropertiesBoxValue(newValue, "leaderToNonLeaderRelationshipMultiplier", leaderToNonLeaderRelationshipMultiplier.value);
        setPropertiesBoxValue(newValue, "nonLeaderToLeaderRelationshipMultiplier", nonLeaderToLeaderRelationshipMultiplier.value);
        setPropertiesBoxValue(newValue, "nonLeaderToNonLeaderRelationshipMultiplier", nonLeaderToNonLeaderRelationshipMultiplier.value);

        // ATTENDANCE
        setPropertiesBoxValue(newValue, "takesAttendance", takesAttendance.value);
        setPropertiesBoxValue(newValue, "allowedScheduleTypes", allowedScheduleTypes.value);
        setPropertiesBoxValue(newValue, "scheduleExclusions", scheduleExclusions.value);
        setPropertiesBoxValue(newValue, "attendanceCountsAsWeekendService", attendanceCountsAsWeekendService.value);
        setPropertiesBoxValue(newValue, "groupAttendanceRequiresLocation", groupAttendanceRequiresLocation.value);
        setPropertiesBoxValue(newValue, "groupAttendanceRequiresSchedule", groupAttendanceRequiresSchedule.value);
        setPropertiesBoxValue(newValue, "sendAttendanceReminder", sendAttendanceReminder.value);
        setPropertiesBoxValue(newValue, "attendanceReminderSystemCommunication", attendanceReminderSystemCommunication.value);
        setPropertiesBoxValue(newValue, "attendanceReminderSendStartOffsetMinutes", attendanceReminderSendStartOffsetMinutes.value);
        setPropertiesBoxValue(newValue, "attendanceReminderFollowupDays", attendanceReminderFollowupDays.value);

        // RSVP
        setPropertiesBoxValue(newValue, "enableRSVP", enableRSVP.value);
        setPropertiesBoxValue(newValue, "rsvpReminderSystemCommunication", rsvpReminderSystemCommunication.value);
        setPropertiesBoxValue(newValue, "rsvpReminderOffsetDays", rsvpReminderOffsetDays.value);

        // CHAT
        setPropertiesBoxValue(newValue, "isChatAllowed", isChatAllowed.value);
        setPropertiesBoxValue(newValue, "isChatEnabledForAllGroups", isChatEnabledForAllGroups.value);
        setPropertiesBoxValue(newValue, "isLeavingChatChannelAllowed", isLeavingChatChannelAllowed.value);
        setPropertiesBoxValue(newValue, "isChatChannelPublic", isChatChannelPublic.value);
        setPropertiesBoxValue(newValue, "isChatChannelAlwaysShown", isChatChannelAlwaysShown.value);
        setPropertiesBoxValue(newValue, "chatPushNotificationMode", chatPushNotificationMode.value);

        // GROUP REQUIREMENTS
        setPropertiesBoxValue(newValue, "groupRequirements", groupRequirements.value);

        // GROUP MEMBER WORKFLOWS
        setPropertiesBoxValue(newValue, "groupMemberWorkflowTriggers", groupMemberWorkflowTriggers.value);

        emit("update:modelValue", newValue);
    });

    // #region Watchers

    watch(() => inheritedGroupType.value?.value, () => {
        loadAttributesForGroupType();
    }, { immediate: true });

    watch(isChatAllowed, async (value) => {
        chatChannelsDisabledMessage.value = null;

        if (value) {
            return;
        }

        const result = await invokeBlockAction<number>("GetChatEnabledGroupCount");

        // Warn if there are any chat channels that will be disabled
        // if they disable chat for this group type.
        if (result.isSuccess && result.data && result.data > 0) {
            chatChannelsDisabledMessage.value = `${result.data.toLocaleString()} chat ${pluralize("channel", result.data)} will be immediately disabled if you disable chat for this group type.`;
        }
    });

    // #endregion Watchers

    // Watch for any changes to props that represent properties and then
    // automatically emit which property changed.
    watchPropertyChanges(propRefs, emit);
</script>
